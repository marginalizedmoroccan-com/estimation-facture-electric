---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Simulateur Basse Tension - estimation facture" activeNav="bt">
    <section class="section">
        <div class="container">
            <div class="section-header" style="text-align:center">
                <h1 class="section-title">
                    Simulateur <span class="gradient-text">Basse Tension</span>
                </h1>
                <p class="section-subtitle">
                    Outil de calcul pour abonnements résidentiels,
                    professionnels et agricoles.
                </p>
            </div>

            <!-- Wizard Steps -->
            <div class="wizard-steps" id="wizardSteps">
                <div class="wizard-step active" data-step="1">
                    <div class="wizard-step-number">1</div>
                    <span class="wizard-step-label">Abonnement</span>
                </div>
                <div class="wizard-step-connector"></div>
                <div class="wizard-step" data-step="2">
                    <div class="wizard-step-number">2</div>
                    <span class="wizard-step-label">Consommation</span>
                </div>
                <div class="wizard-step-connector"></div>
                <div class="wizard-step" data-step="3">
                    <div class="wizard-step-number">3</div>
                    <span class="wizard-step-label">Résultat</span>
                </div>
            </div>

            <div class="wizard-container">
                <!-- Step 1: Subscription Selection -->
                <div class="wizard-panel active" id="step1">
                    <div
                        class="bill-card"
                        style="max-width:700px;margin:0 auto"
                    >
                        <div style="padding:32px">
                            <h2
                                style="font-size:16px;font-weight:800;margin-bottom:24px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                            >
                                <span style="color:var(--onee-blue);opacity:0.5"
                                    >01.</span
                                > Paramètres d'abonnement
                            </h2>

                            <div class="form-group">
                                <label for="selectTarif">
                                    Usage Tarifaire
                                    <span class="form-hint"
                                        >Sélectionnez la catégorie de votre
                                        contrat</span
                                    >
                                </label>
                                <select class="form-select" id="selectTarif">
                                    <option value="">— Sélectionner —</option>
                                    <option value="domestique"
                                        >Domestique (Éclairage privé)</option
                                    >
                                    <option value="patente"
                                        >Professionnel (Patenté)</option
                                    >
                                    <option value="force_motrice_industrielle"
                                        >Force Motrice Industrielle</option
                                    >
                                    <option value="force_motrice_agricole"
                                        >Force Motrice Agricole</option
                                    >
                                </select>
                            </div>

                            <div
                                class="tariff-info"
                                id="tariffInfo"
                                style="display:none;padding:16px;margin-bottom:24px;background:#F8FAFC;border-radius:6px;border-left:3px solid var(--onee-blue)"
                            >
                                <p
                                    id="tariffDesc"
                                    style="font-size:13px;color:var(--w-color-primary-20);line-height:1.6;font-weight:500"
                                >
                                </p>
                            </div>

                            <div class="form-group">
                                <label for="selectCompteur">
                                    Type de Branchement
                                    <span class="form-hint"
                                        >Type de compteur installé</span
                                    >
                                </label>
                                <select class="form-select" id="selectCompteur">
                                    <option value="">— Sélectionner —</option>
                                    <option value="2fils"
                                        >Monophasé (2 Fils)</option
                                    >
                                    <option value="4fils_5_15"
                                        >Triphasé (4 Fils 5-15A)</option
                                    >
                                    <option value="4fils_20_60"
                                        >Triphasé (4 Fils 20-60A)</option
                                    >
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Transformateur de Courant (TC)</label>
                                <div
                                    style="display:flex;gap:24px;align-items:center;margin-top:8px;"
                                >
                                    <label
                                        style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600;font-size:14px;color:var(--onee-blue)"
                                    >
                                        <input
                                            type="radio"
                                            name="tc_radio"
                                            value="non"
                                            checked
                                            id="tcNon"
                                            style="width:16px;height:16px"
                                        /> Non
                                    </label>
                                    <label
                                        style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600;font-size:14px;color:var(--onee-blue)"
                                    >
                                        <input
                                            type="radio"
                                            name="tc_radio"
                                            value="oui"
                                            id="tcOui"
                                            style="width:16px;height:16px"
                                        /> Oui
                                    </label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="tcRatio"
                                        value="1"
                                        min="1"
                                        style="width:100px;display:none;margin-left:auto"
                                        placeholder="Ratio"
                                    />
                                </div>
                            </div>

                            <div
                                style="display:flex;gap:16px;justify-content:flex-end;margin-top:40px"
                            >
                                <a href="/" class="btn btn-secondary">Annuler</a
                                >
                                <button
                                    class="btn btn-primary"
                                    id="toStep2"
                                    disabled
                                    style="padding: 10px 24px"
                                >
                                    Suivant
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Consumption Input -->
                <div class="wizard-panel" id="step2">
                    <div
                        class="bill-card"
                        style="max-width:700px;margin:0 auto"
                    >
                        <div style="padding:32px">
                            <h2
                                style="font-size:16px;font-weight:800;margin-bottom:24px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                            >
                                <span style="color:var(--onee-blue);opacity:0.5"
                                    >02.</span
                                > Saisie des données
                            </h2>

                            <div
                                class="form-row-inline"
                                style="margin-bottom: 24px;"
                            >
                                <div class="form-group-inline">
                                    <label for="consumption"
                                        >Consommation (kWh)</label
                                    >
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="consumption"
                                        min="0"
                                        placeholder="Ex: 250"
                                    />
                                </div>
                                <div class="form-group-inline">
                                    <label for="days">Période (Jours)</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="days"
                                        min="1"
                                        max="365"
                                        value="30"
                                    />
                                </div>
                            </div>

                            <div class="quick-select" style="margin-top:16px">
                                <span
                                    style="font-size:12px;font-weight:700;color:var(--w-color-primary-30);text-transform:uppercase;letter-spacing:0.5px;margin-right:12px"
                                    >Saisie rapide :</span
                                >
                                <button class="quick-btn" data-kwh="80"
                                    >80</button
                                >
                                <button class="quick-btn" data-kwh="150"
                                    >150</button
                                >
                                <button class="quick-btn" data-kwh="250"
                                    >250</button
                                >
                                <button class="quick-btn" data-kwh="400"
                                    >400</button
                                >
                                <button class="quick-btn" data-kwh="600"
                                    >600</button
                                >
                            </div>

                            <div
                                style="display:flex;gap:16px;justify-content:flex-end;margin-top:40px"
                            >
                                <button
                                    class="btn btn-secondary"
                                    id="backToStep1">Retour</button
                                >
                                <button
                                    class="btn btn-primary"
                                    id="calculateBtn"
                                    disabled
                                    style="padding: 10px 24px"
                                >
                                    Générer l'estimation
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 3: Results -->
                <div class="wizard-panel" id="step3">
                    <div
                        class="bill-card"
                        style="max-width:850px;margin:0 auto"
                    >
                        <div style="padding:40px">
                            <!-- Header -->
                            <div
                                style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;border-bottom:2px solid #F1F5F9;padding-bottom:24px"
                            >
                                <div>
                                    <h2
                                        style="font-size:22px;font-weight:800;color:var(--onee-blue)"
                                    >
                                        Rapport d'Estimation
                                    </h2>
                                    <p
                                        style="font-size:13px;color:var(--w-color-primary-30);margin-top:6px;font-weight:600"
                                        id="resultMeta"
                                    >
                                    </p>
                                </div>
                                <div style="text-align:right">
                                    <div
                                        style="font-size:12px;font-weight:800;color:var(--onee-blue);opacity:0.5;text-transform:uppercase;letter-spacing:1px"
                                    >
                                        Document interne
                                    </div>
                                </div>
                            </div>

                            <!-- Total Amount Highlight -->
                            <div
                                class="result-total"
                                style="text-align:center;padding:32px;margin-bottom:40px;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:12px"
                            >
                                <p
                                    style="font-size:13px;font-weight:700;color:var(--w-color-primary-30);margin-bottom:8px;text-transform:uppercase;letter-spacing:1px"
                                >
                                    Net à payer estimé (TTC)
                                </p>
                                <div
                                    class="result-amount"
                                    style="font-size:48px;font-weight:900;color:var(--onee-blue)"
                                >
                                    <span id="totalAmount">0.00</span>
                                    <span style="font-size:20px;margin-left:4px"
                                        >DH</span
                                    >
                                </div>
                                <div
                                    style="display:flex;justify-content:center;gap:32px;margin-top:20px;font-size:14px;font-weight:600;color:var(--w-color-primary-30)"
                                >
                                    <span
                                        >Espèce : <span
                                            id="totalEspece"
                                            style="color:var(--onee-blue)"
                                            >0.00</span
                                        > DH</span
                                    >
                                    <span
                                        >Chèque : <span
                                            id="totalCheque"
                                            style="color:var(--onee-blue)"
                                            >0.00</span
                                        > DH</span
                                    >
                                </div>
                            </div>

                            <!-- Consumption Breakdown -->
                            <h3
                                style="font-size:14px;font-weight:800;margin-bottom:16px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:0.5px"
                            >
                                Décomposition du calcul
                            </h3>
                            <table
                                class="bill-table"
                                style="margin-bottom:32px"
                            >
                                <thead>
                                    <tr>
                                        <th>Tranche de consommation</th>
                                        <th class="amount">Volume (kWh)</th>
                                        <th class="amount">Prix unit.</th>
                                        <th class="amount">Total HT</th>
                                    </tr>
                                </thead>
                                <tbody id="trancheRows"></tbody>
                            </table>

                            <!-- Bill Details -->
                            <table class="bill-table">
                                <tbody style="font-weight:500">
                                    <tr>
                                        <td>Maturité Consommations (RC)</td>
                                        <td class="amount" id="rcAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>Redevances Fixes (RF)</td>
                                        <td class="amount" id="rfAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr
                                        style="background:var(--onee-background);font-weight:800;color:var(--onee-blue)"
                                    >
                                        <td>Sous-total Hors Taxes</td>
                                        <td class="amount" id="totalHTAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>Taxe TPPA</td>
                                        <td class="amount" id="tppaAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>Total TVA Applicable</td>
                                        <td class="amount" id="tvaAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>Timbre Fiscal</td>
                                        <td class="amount" id="timbreAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                    <tr
                                        style="background:var(--onee-background);font-weight:800;color:var(--onee-blue)"
                                    >
                                        <td>Cumul des Taxes & Droits</td>
                                        <td class="amount" id="totalTaxesAmount"
                                            >0.00</td
                                        >
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td style="font-weight:900;padding:18px"
                                            >TOTAL GÉNÉRAL TTC</td
                                        >
                                        <td
                                            class="amount"
                                            style="font-weight:900;padding:18px;font-size:18px"
                                            id="totalTTCAmount">0.00</td
                                        >
                                    </tr>
                                </tfoot>
                            </table>

                            <!-- TVA Detail (collapsible) -->
                            <details
                                style="margin-top:24px;border:1px solid #E2E8F0;border-radius:8px"
                            >
                                <summary
                                    style="font-size:13px;font-weight:800;cursor:pointer;color:var(--onee-blue);padding:12px 16px;background:#F8FAFC;text-transform:uppercase"
                                >
                                    Détail de la T.V.A
                                </summary>
                                <div style="padding:16px">
                                    <table
                                        class="bill-table"
                                        style="margin:0;border:none"
                                    >
                                        <tbody style="font-size:13px">
                                            <tr>
                                                <td style="border:none"
                                                    >TVA sur Consommations (18%)</td
                                                >
                                                <td
                                                    class="amount"
                                                    id="tvaRCDetail"
                                                    style="border:none">0.00</td
                                                >
                                            </tr>
                                            <tr>
                                                <td style="border:none"
                                                    >TVA sur TPPA (20%)</td
                                                >
                                                <td
                                                    class="amount"
                                                    id="tvaTPPADetail"
                                                    style="border:none">0.00</td
                                                >
                                            </tr>
                                            <tr>
                                                <td style="border:none"
                                                    >TVA sur Entretien (20%)</td
                                                >
                                                <td
                                                    class="amount"
                                                    id="tvaEntretienDetail"
                                                    style="border:none">0.00</td
                                                >
                                            </tr>
                                            <tr>
                                                <td style="border:none"
                                                    >TVA sur Location (15%)</td
                                                >
                                                <td
                                                    class="amount"
                                                    id="tvaLocationDetail"
                                                    style="border:none">0.00</td
                                                >
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </details>

                            <!-- Disclaimer -->
                            <div
                                style="margin-top:40px;padding:20px;background:#FEFCE8;border:1px solid #FEF08A;border-radius:8px;text-align:center"
                            >
                                <p
                                    style="font-size:12px;color:#854D0E;font-weight:600;line-height:1.6"
                                >
                                    IMPORTANT : Cette simulation est fournie
                                    uniquement à titre informatif et s'appuie
                                    sur les grilles tarifaires standard. Le
                                    montant réel figurant sur votre facture
                                    officielle peut varier selon des paramètres
                                    spécifiques à votre contrat.
                                </p>
                            </div>

                            <div
                                style="display:flex;gap:16px;justify-content:center;margin-top:40px;flex-wrap:wrap"
                                class="no-print"
                            >
                                <button
                                    class="btn btn-secondary"
                                    id="backToStep2">Réajuster</button
                                >
                                <button
                                    class="btn btn-primary"
                                    id="saveBtn"
                                    style="padding: 10px 24px"
                                >
                                    Enregistrer
                                </button>
                                <button
                                    class="btn btn-primary"
                                    onclick="window.print()"
                                    style="padding: 10px 24px; background: #1E293B; border-color: #1E293B"
                                >
                                    Imprimer
                                </button>
                                <button class="btn btn-secondary" id="newCalc"
                                    >Nouveau calcul</button
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .wizard-container {
        position: relative;
    }
    .wizard-panel {
        display: none;
    }
    .wizard-panel.active {
        display: block;
        animation: fadeInUp 0.4s ease forwards;
    }

    .quick-select {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .quick-btn {
        padding: 6px 16px;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: #fff;
        color: var(--onee-blue);
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
    }

    .quick-btn:hover,
    .quick-btn.active {
        border-color: var(--onee-blue);
        background: #f1f5f9;
    }

    details summary {
        list-style: none;
    }
    details summary::-webkit-details-marker {
        display: none;
    }

    /* Custom Radio Styling */
    input[type="radio"] {
        accent-color: var(--onee-blue);
    }
</style>

<script>
    // ============================================
    // BT Simulator Client-Side Logic
    // ============================================

    // Tariff data (embedded for client-side)
    const BT_TRANCHES_LOW = [
        {
            tranche: 1,
            nameFr: "Tranche 1",
            maxKwh: 100,
            unitPrice: 0.76356,
        },
        {
            tranche: 2,
            nameFr: "Tranche 2",
            maxKwh: 150,
            unitPrice: 0.9095,
        },
    ];

    const BT_TRANCHES_HIGH = [
        {
            tranche: 3,
            nameFr: "Tranche 3",
            minKwh: 151,
            maxKwh: 210,
            unitPrice: 0.9095,
        },
        {
            tranche: 4,
            nameFr: "Tranche 4",
            minKwh: 211,
            maxKwh: 310,
            unitPrice: 0.9895,
        },
        {
            tranche: 5,
            nameFr: "Tranche 5",
            minKwh: 311,
            maxKwh: 510,
            unitPrice: 1.17094,
        },
        {
            tranche: 6,
            nameFr: "Tranche 6",
            minKwh: 511,
            maxKwh: Infinity,
            unitPrice: 1.35238,
        },
    ];

    const METER_FEES: Record<
        string,
        { rf: number; entretien: number; location: number }
    > = {
        "2fils": { rf: 17.42, entretien: 7.86, location: 9.56 },
        "4fils_5_15": { rf: 33.28, entretien: 15, location: 18.28 },
        "4fils_20_60": { rf: 44.57, entretien: 15, location: 29.57 },
    };

    const TARIFF_DESCRIPTIONS: Record<string, string> = {
        domestique:
            "Destiné aux clients particuliers pour un usage strictement résidentiel sans activité commerciale.",
        patente:
            "Applicable aux clients exerçant une activité soumise à la taxe professionnelle (commerces, professions libérales).",
        force_motrice_industrielle:
            "Destiné à l'alimentation des équipements industriels et moteurs hors usage domestique.",
        force_motrice_agricole:
            "Tarif préférentiel réservé aux installations de pompage et équipements agricoles.",
    };

    function round2(n: number): number {
        return Math.round((n + Number.EPSILON) * 100) / 100;
    }
    function floor2(n: number): number {
        return Math.floor(n * 100) / 100;
    }
    function fmt(n: number): string {
        return n.toFixed(2);
    }

    // DOM elements
    const selectTarif = document.getElementById(
        "selectTarif"
    ) as unknown as HTMLSelectElement;
    const selectCompteur = document.getElementById(
        "selectCompteur"
    ) as unknown as HTMLSelectElement;
    const tariffInfo = document.getElementById("tariffInfo") as HTMLDivElement;
    const tariffDesc = document.getElementById(
        "tariffDesc"
    ) as HTMLParagraphElement;
    const tcOui = document.getElementById("tcOui") as HTMLInputElement;
    const tcNon = document.getElementById("tcNon") as HTMLInputElement;
    const tcRatio = document.getElementById("tcRatio") as HTMLInputElement;
    const toStep2 = document.getElementById("toStep2") as HTMLButtonElement;
    const backToStep1 = document.getElementById(
        "backToStep1"
    ) as HTMLButtonElement;
    const backToStep2 = document.getElementById(
        "backToStep2"
    ) as HTMLButtonElement;
    const calculateBtn = document.getElementById(
        "calculateBtn"
    ) as HTMLButtonElement;
    const newCalc = document.getElementById("newCalc") as HTMLButtonElement;
    const consumption = document.getElementById(
        "consumption"
    ) as HTMLInputElement;
    const daysInput = document.getElementById("days") as HTMLInputElement;

    // Step management
    function goToStep(step: number): void {
        document
            .querySelectorAll(".wizard-panel")
            .forEach((p) => p.classList.remove("active"));
        document.getElementById("step" + step)!.classList.add("active");
        document.querySelectorAll<HTMLElement>(".wizard-step").forEach((s) => {
            const sn = parseInt(s.dataset.step || "0");
            s.classList.remove("active", "completed");
            if (sn < step) s.classList.add("completed");
            if (sn === step) s.classList.add("active");
        });
    }

    // Validate step 1
    function validateStep1(): void {
        toStep2.disabled = !(selectTarif.value && selectCompteur.value);
    }

    selectTarif.addEventListener("change", () => {
        validateStep1();
        if (selectTarif.value && TARIFF_DESCRIPTIONS[selectTarif.value]) {
            tariffDesc.textContent = TARIFF_DESCRIPTIONS[selectTarif.value];
            tariffInfo.style.display = "block";
        } else {
            tariffInfo.style.display = "none";
        }
    });
    selectCompteur.addEventListener("change", validateStep1);

    // TC toggle
    document
        .querySelectorAll<HTMLInputElement>('input[name="tc_radio"]')
        .forEach((r) => {
            r.addEventListener("change", () => {
                tcRatio.style.display = tcOui.checked ? "block" : "none";
                if (tcNon.checked) tcRatio.value = "1";
            });
        });

    // Navigation
    toStep2.addEventListener("click", () => goToStep(2));
    backToStep1.addEventListener("click", () => goToStep(1));
    backToStep2.addEventListener("click", () => goToStep(2));
    newCalc.addEventListener("click", () => {
        selectTarif.value = "";
        selectCompteur.value = "";
        consumption.value = "";
        daysInput.value = "30";
        tariffInfo.style.display = "none";
        validateStep1();
        goToStep(1);
    });

    // Validate step 2
    function validateStep2(): void {
        calculateBtn.disabled = !(
            consumption.value && parseInt(consumption.value) >= 0
        );
    }
    consumption.addEventListener("input", validateStep2);

    // Quick buttons
    document
        .querySelectorAll<HTMLButtonElement>(".quick-btn")
        .forEach((btn) => {
            btn.addEventListener("click", () => {
                consumption.value = btn.dataset.kwh || "";
                document
                    .querySelectorAll(".quick-btn")
                    .forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");
                validateStep2();
            });
        });

    // === CALCULATE ===
    calculateBtn.addEventListener("click", () => {
        const cons =
            parseInt(consumption.value) * parseInt(tcRatio.value || "1");
        const days = parseInt(daysInput.value) || 30;
        const meter = selectCompteur.value;
        const fees = METER_FEES[meter];

        // Calculate tranches
        const tranches: Array<{
            nameFr: string;
            unitPrice: number;
            quantity: number;
            amount: number;
        }> = [];
        const isNormal = days >= 28 && days <= 31;

        if (isNormal) {
            if (cons <= 150) {
                if (cons <= 100) {
                    tranches.push({
                        ...BT_TRANCHES_LOW[0],
                        quantity: cons,
                        amount: round2(cons * BT_TRANCHES_LOW[0].unitPrice),
                    });
                } else {
                    tranches.push({
                        ...BT_TRANCHES_LOW[0],
                        quantity: 100,
                        amount: round2(100 * BT_TRANCHES_LOW[0].unitPrice),
                    });
                    tranches.push({
                        ...BT_TRANCHES_LOW[1],
                        quantity: cons - 100,
                        amount: round2(
                            (cons - 100) * BT_TRANCHES_LOW[1].unitPrice
                        ),
                    });
                }
            } else {
                const t =
                    BT_TRANCHES_HIGH.find(
                        (t) => cons >= t.minKwh && cons <= t.maxKwh
                    ) || BT_TRANCHES_HIGH[3];
                tranches.push({
                    ...t,
                    quantity: cons,
                    amount: round2(cons * t.unitPrice),
                });
            }
        } else {
            const tr1 = Math.ceil((100 * days) / 30);
            const tr2 = (150 * days) / (365 / 12);
            if (cons <= tr2) {
                if (cons <= tr1) {
                    tranches.push({
                        ...BT_TRANCHES_LOW[0],
                        quantity: Math.round(cons),
                        amount: round2(cons * BT_TRANCHES_LOW[0].unitPrice),
                    });
                } else {
                    tranches.push({
                        ...BT_TRANCHES_LOW[0],
                        quantity: tr1,
                        amount: round2(tr1 * BT_TRANCHES_LOW[0].unitPrice),
                    });
                    tranches.push({
                        ...BT_TRANCHES_LOW[1],
                        quantity: Math.round(cons - tr1),
                        amount: round2(
                            (cons - tr1) * BT_TRANCHES_LOW[1].unitPrice
                        ),
                    });
                }
            } else {
                const tr3sup = Math.ceil((210 * days) / 30);
                const tr4sup = Math.ceil((310 * days) / 30);
                const tr5sup = Math.ceil((510 * days) / 30);
                let t;
                if (cons <= tr3sup) t = BT_TRANCHES_HIGH[0];
                else if (cons <= tr4sup) t = BT_TRANCHES_HIGH[1];
                else if (cons <= tr5sup) t = BT_TRANCHES_HIGH[2];
                else t = BT_TRANCHES_HIGH[3];
                tranches.push({
                    ...t,
                    quantity: cons,
                    amount: round2(cons * t.unitPrice),
                });
            }
        }

        const rc = round2(tranches.reduce((s: number, t) => s + t.amount, 0));
        const rf = fees.rf;
        const totalHT = round2(rc + rf);

        // TPPA
        let seuilExoneration = isNormal ? 200 : Math.ceil((200 * days) / 30);
        let plafondTPPA = isNormal
            ? round2(100 / 1.2)
            : round2(((100 / 1.2) * days) / 30);
        let tppa = 0;
        if (cons > seuilExoneration) {
            const ratio = isNormal ? 1 : days / 30;
            tppa = round2(
                100 * ratio * 0.08333 +
                    100 * ratio * 0.125 +
                    (cons - seuilExoneration) * 0.18667
            );
            if (tppa > plafondTPPA) tppa = plafondTPPA;
        }

        // TVA
        const tvaRC = floor2(rc * 0.18);
        const tvaTPPA = floor2(tppa * 0.2);
        const tvaEntretien = floor2(fees.entretien * 0.2);
        const tvaLocation = floor2(fees.location * 0.15);
        const tva = round2(tvaRC + tvaTPPA + tvaEntretien + tvaLocation);

        // Timbre fiscal
        const timbre = round2((totalHT + tppa + tva) * 0.0025);

        // Totals
        const totalTaxes = round2(tppa + tva + timbre);
        const totalEspece = round2(totalHT + totalTaxes);
        const totalCheque = round2(totalEspece - timbre);

        // Render results
        const trancheRows = document.getElementById("trancheRows")!;
        trancheRows.innerHTML = tranches
            .map(
                (t) => `
            <tr>
                <td>${t.nameFr}</td>
                <td class="amount">${t.quantity}</td>
                <td class="amount">${t.unitPrice.toFixed(5)}</td>
                <td class="amount">${fmt(t.amount)}</td>
            </tr>
        `
            )
            .join("");

        document.getElementById("rcAmount")!.textContent = fmt(rc);
        document.getElementById("rfAmount")!.textContent = fmt(rf);
        document.getElementById("totalHTAmount")!.textContent = fmt(totalHT);
        document.getElementById("tppaAmount")!.textContent = fmt(tppa);
        document.getElementById("tvaAmount")!.textContent = fmt(tva);
        document.getElementById("timbreAmount")!.textContent = fmt(timbre);
        document.getElementById("totalTaxesAmount")!.textContent =
            fmt(totalTaxes);
        document.getElementById("totalTTCAmount")!.textContent =
            fmt(totalEspece);
        document.getElementById("totalAmount")!.textContent = fmt(totalEspece);
        document.getElementById("totalEspece")!.textContent = fmt(totalEspece);
        document.getElementById("totalCheque")!.textContent = fmt(totalCheque);

        // TVA details
        document.getElementById("tvaRCDetail")!.textContent = fmt(tvaRC);
        document.getElementById("tvaTPPADetail")!.textContent = fmt(tvaTPPA);
        document.getElementById("tvaEntretienDetail")!.textContent =
            fmt(tvaEntretien);
        document.getElementById("tvaLocationDetail")!.textContent =
            fmt(tvaLocation);

        // Meta
        const tarifLabel = selectTarif.options[selectTarif.selectedIndex].text;
        const compteurLabel =
            selectCompteur.options[selectCompteur.selectedIndex].text;
        const metaStr = `${tarifLabel} • ${compteurLabel} • ${cons} kWh • ${days} jours`;
        document.getElementById("resultMeta")!.textContent = metaStr;

        // Save logic
        const saveBtn = document.getElementById("saveBtn")!;
        (saveBtn as any).onclick = () => {
            const history = JSON.parse(
                localStorage.getItem("estimation_history") || "[]"
            );
            const entry = {
                id: Date.now(),
                type: "bt",
                date: new Date().toISOString(),
                label: metaStr,
                total: totalEspece,
                details: {
                    tarif: selectTarif.value,
                    compteur: selectCompteur.value,
                    cons,
                    days,
                    rc,
                    rf,
                    totalHT,
                    tppa,
                    tva,
                    timbre,
                    totalEspece,
                },
            };
            history.unshift(entry);
            localStorage.setItem("estimation_history", JSON.stringify(history));
            saveBtn.setAttribute("disabled", "true");
            saveBtn.textContent = "Enregistré";
            saveBtn.style.opacity = "0.5";
        };

        goToStep(3);
    });
</script>
