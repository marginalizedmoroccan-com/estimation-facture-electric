---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Vos Droits face à l'Administration - estimation facture"
    activeNav="droits"
>
    <section class="section">
        <div class="container" style="max-width: 900px;">
            <div class="section-header" style="text-align:center">
                <div class="hero-badge" style="margin: 0 auto 16px;">
                    <span>Charte des Services Publics</span>
                </div>
                <h1 class="section-title">
                    Vos <span class="gradient-text">Droits</span> face à l'Administration
                </h1>
                <p class="section-subtitle">
                    En tant que citoyen marocain, vous disposez de droits
                    fondamentaux garantis par la loi pour assurer la
                    transparence, la célérité et la qualité des services
                    publics.
                </p>
            </div>

            <div class="grid grid-1" style="gap: 32px; margin-top: 48px;">
                <!-- Loi 55.19 -->
                <div
                    class="bill-card animate-fade-in"
                    style="animation-delay: 0.1s; border-left: 4px solid var(--onee-blue);"
                >
                    <div class="page-card">
                        <div
                            style="display: flex; gap: 32px; align-items: flex-start;"
                        >
                            <div
                                style="background: var(--onee-background); color: var(--onee-blue); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 900; border: 1px solid var(--onee-card-border); flex-shrink: 0;"
                            >
                                55.19
                            </div>
                            <div>
                                <h2
                                    style="font-size: 20px; font-weight: 800; margin-bottom: 16px; color: var(--onee-blue); letter-spacing: -0.5px;"
                                >
                                    Simplification des Procédures
                                    Administratives
                                </h2>
                                <p
                                    style="color: var(--w-color-primary-30); line-height: 1.8; font-size: 15px; font-weight: 500;"
                                >
                                    Le fondement de la modernisation
                                    administrative au Maroc. Cette loi interdit
                                    aux administrations d'exiger des documents
                                    déjà en leur possession ou de multiplier les
                                    copies inutiles.
                                </p>
                                <ul
                                    style="margin-top: 24px; color: var(--w-color-primary-30); font-size: 14px; list-style: none; padding: 0; display: grid; gap: 12px;"
                                >
                                    <li
                                        style="display: flex; gap: 12px; align-items: flex-start;"
                                    >
                                        <div
                                            style="color: var(--onee-blue); margin-top: 4px;"
                                        >
                                            <svg
                                                width="14"
                                                height="14"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="3"
                                                ><polyline
                                                    points="20 6 9 17 4 12"
                                                ></polyline>
                                            </svg>
                                        </div>
                                        <span
                                            >Suppression de la <strong
                                                >légalisation de signature</strong
                                            > (Gualisation) pour la majorité des
                                            dossiers de facturation.</span
                                        >
                                    </li>
                                    <li
                                        style="display: flex; gap: 12px; align-items: flex-start;"
                                    >
                                        <div
                                            style="color: var(--onee-blue); margin-top: 4px;"
                                        >
                                            <svg
                                                width="14"
                                                height="14"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="3"
                                                ><polyline
                                                    points="20 6 9 17 4 12"
                                                ></polyline>
                                            </svg>
                                        </div>
                                        <span
                                            ><strong
                                                >Délai de réponse obligatoire :</strong
                                            > L'administration a l'obligation de
                                            traiter votre dossier sous 30 à 60 jours.</span
                                        >
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Loi 31.13 -->
                <div
                    class="bill-card animate-fade-in"
                    style="animation-delay: 0.2s; border-left: 4px solid var(--onee-blue);"
                >
                    <div class="page-card">
                        <div
                            style="display: flex; gap: 32px; align-items: flex-start;"
                        >
                            <div
                                style="background: var(--onee-background); color: var(--onee-blue); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 900; border: 1px solid var(--onee-card-border); flex-shrink: 0;"
                            >
                                31.13
                            </div>
                            <div>
                                <h2
                                    style="font-size: 20px; font-weight: 800; margin-bottom: 16px; color: var(--onee-blue); letter-spacing: -0.5px;"
                                >
                                    Droit d'Accès à l'Information Public
                                </h2>
                                <p
                                    style="color: var(--w-color-primary-30); line-height: 1.8; font-size: 15px; font-weight: 500;"
                                >
                                    Garantit à tout citoyen le droit d'obtenir
                                    des informations précises sur les tarifs,
                                    les modes de calcul et les décisions
                                    réglementaires des services publics
                                    d'énergie.
                                </p>
                                <div
                                    style="margin-top: 24px; padding: 20px; background: #FFFBEB; border-radius: 8px; border: 1px solid #FEF3C7;"
                                >
                                    <p
                                        style="font-size: 13px; color: #92400E; font-weight: 600;"
                                    >
                                        <strong style="color:#B45309"
                                            >Délai Réglementaire :</strong
                                        > L'administration dispose d'un délai strict
                                        de <strong>20 jours ouvrables</strong> pour
                                        répondre à vos audits.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ANRE Methodology -->
                <div
                    class="bill-card animate-fade-in"
                    style="animation-delay: 0.25s; border-left: 4px solid var(--onee-blue);"
                >
                    <div class="page-card">
                        <div
                            style="display: flex; gap: 32px; align-items: flex-start;"
                        >
                            <div
                                style="background: var(--onee-background); color: var(--onee-blue); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 900; border: 1px solid var(--onee-card-border); flex-shrink: 0;"
                            >
                                ANRE
                            </div>
                            <div>
                                <div
                                    style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;"
                                >
                                    <h2
                                        style="font-size: 20px; font-weight: 800; color: var(--onee-blue); margin: 0; letter-spacing: -0.5px;"
                                    >
                                        Régulation Tarifaire & Transparence
                                    </h2>
                                    <span class="tag-label tag-label-info"
                                        >ANRE 2025</span
                                    >
                                </div>
                                <p
                                    style="color: var(--w-color-primary-30); line-height: 1.8; font-size: 15px; font-weight: 500;"
                                >
                                    L'Autorité Nationale de Régulation de
                                    l'Électricité a instauré fin févier 2025 un
                                    cadre strict pour la tarification TURD,
                                    visant une transparence totale des coûts.
                                </p>
                                <div
                                    class="grid grid-2"
                                    style="gap: 20px; margin-top: 24px;"
                                >
                                    <div
                                        class="glass-card"
                                        style="padding: 20px; border-radius: 12px; background: var(--onee-background);"
                                    >
                                        <div
                                            style="font-weight: 900; color: var(--onee-blue); font-size: 22px; letter-spacing: -0.5px;"
                                        >
                                            5,92 cts/kWh
                                        </div>
                                        <div
                                            style="font-size: 11px; color: var(--w-color-primary-30); text-transform: uppercase; font-weight: 800; margin-top: 4px; opacity: 0.7;"
                                        >
                                            TURD (MT) 2025-2027
                                        </div>
                                    </div>
                                    <div
                                        class="glass-card"
                                        style="padding: 20px; border-radius: 12px; background: var(--onee-background);"
                                    >
                                        <div
                                            style="font-weight: 900; color: var(--onee-blue); font-size: 22px; letter-spacing: -0.5px;"
                                        >
                                            National
                                        </div>
                                        <div
                                            style="font-size: 11px; color: var(--w-color-primary-30); text-transform: uppercase; font-weight: 800; margin-top: 4px; opacity: 0.7;"
                                        >
                                            Tarif unifié régional
                                        </div>
                                    </div>
                                </div>
                                <a
                                    href="https://anre.ma/wp-content/uploads/2025/02/ANRE-TarifsMTDistribution-MethodologieTarifaire-VF.pdf"
                                    target="_blank"
                                    style="display: flex; align-items: center; gap: 8px; margin-top: 24px; font-size: 13px; color: var(--onee-blue); text-decoration: none; font-weight: 700; background: var(--onee-background); width: fit-content; padding: 12px 20px; border-radius: 8px; border: 1px solid var(--onee-card-border); transition: all 0.2s ease;"
                                >
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        ><path
                                            d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                                        ></path><polyline
                                            points="14 2 14 8 20 8"
                                        ></polyline><line
                                            x1="12"
                                            y1="18"
                                            x2="12"
                                            y2="12"></line><polyline
                                            points="9 15 12 18 15 15"
                                        ></polyline>
                                    </svg>
                                    Document Officiel ANRE (PDF)
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Réclamations -->
                <div
                    class="bill-card animate-fade-in"
                    style="animation-delay: 0.3s; border-left: 4px solid var(--onee-blue);"
                >
                    <div class="page-card">
                        <div
                            style="display: flex; gap: 32px; align-items: flex-start;"
                        >
                            <div
                                style="background: var(--onee-background); color: var(--onee-blue); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 900; border: 1px solid var(--onee-card-border); flex-shrink: 0;"
                            >
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    ><path
                                        d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h2
                                    style="font-size: 20px; font-weight: 800; margin-bottom: 16px; color: var(--onee-blue); letter-spacing: -0.5px;"
                                >
                                    Portails de Recours Nationaux
                                </h2>
                                <p
                                    style="color: var(--w-color-primary-30); line-height: 1.8; font-size: 15px; font-weight: 500;"
                                >
                                    En cas de litige persistant ou d'absence de
                                    réponse de votre SRM, vous pouvez saisir les
                                    autorités de médiation nationales.
                                </p>
                                <div
                                    class="grid grid-2"
                                    style="gap: 20px; margin-top: 24px;"
                                >
                                    <a
                                        href="https://www.chikaya.ma"
                                        target="_blank"
                                        class="glass-card"
                                        style="padding: 24px; text-decoration: none; border-radius: 12px; background: var(--onee-background); transition: all 0.3s ease; border: 1px solid var(--onee-card-border);"
                                    >
                                        <div
                                            style="color: var(--onee-blue); font-weight: 900; font-size: 16px; margin-bottom: 4px;"
                                        >
                                            Chikaya.ma
                                        </div>
                                        <div
                                            style="font-size: 11px; color: var(--w-color-primary-30); font-weight: 800; text-transform: uppercase; opacity: 0.7;"
                                        >
                                            Réclamations État
                                        </div>
                                    </a>
                                    <a
                                        href="https://www.mediateur.ma"
                                        target="_blank"
                                        class="glass-card"
                                        style="padding: 24px; text-decoration: none; border-radius: 12px; background: var(--onee-background); transition: all 0.3s ease; border: 1px solid var(--onee-card-border);"
                                    >
                                        <div
                                            style="color: var(--onee-blue); font-weight: 900; font-size: 16px; margin-bottom: 4px;"
                                        >
                                            Le Médiateur
                                        </div>
                                        <div
                                            style="font-size: 11px; color: var(--w-color-primary-30); font-weight: 800; text-transform: uppercase; opacity: 0.7;"
                                        >
                                            Institutions du Royaume
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charte des Services Publics -->
                <div
                    class="bill-card animate-fade-in"
                    style="animation-delay: 0.4s; background: var(--onee-blue);"
                >
                    <div style="padding: 48px;">
                        <h2
                            style="font-size: 20px; font-weight: 900; margin-bottom: 32px; color: #fff; text-align: center; text-transform: uppercase; letter-spacing: 2px;"
                        >
                            Valeurs du Service Public
                        </h2>
                        <div class="grid grid-3" style="gap: 24px;">
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    01
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Transparence
                                </div>
                            </div>
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    02
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Équité
                                </div>
                            </div>
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    03
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Continuité
                                </div>
                            </div>
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    04
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Proximité
                                </div>
                            </div>
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    05
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Célérité
                                </div>
                            </div>
                            <div style="text-align:center">
                                <div
                                    style="font-weight: 950; color: var(--onee-gold); font-size: 24px; margin-bottom: 8px;"
                                >
                                    06
                                </div>
                                <div
                                    style="color: #fff; font-size: 13px; font-weight: 700; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.5px;"
                                >
                                    Impartialité
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div
                style="margin-top: 80px; text-align: center; opacity: 0.4; font-size: 11px; font-weight: 800; letter-spacing: 1px;"
            >
                <p>REF : BULLETIN OFFICIEL DU ROYAUME DU MAROC — 2021-2025.</p>
            </div>
        </div>
    </section>
</Layout>

<style>
    .animate-fade-in {
        opacity: 0;
        transform: translateY(10px);
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .grid-3 {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
</style>
