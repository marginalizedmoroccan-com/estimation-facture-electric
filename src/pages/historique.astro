---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Historique des Estimations - estimation facture"
    activeNav="historique"
>
    <section class="section">
        <div class="container">
            <div class="section-header">
                <h1 class="section-title">
                    Mon <span class="gradient-text">Historique</span>
                </h1>
                <p class="section-subtitle">
                    Retrouvez et gérez vos simulations enregistrées localement.
                </p>
            </div>

            <div id="historyContainer" class="animate-fade-in">
                <div
                    class="glass-card"
                    style="padding: 48px; text-align: center; border-style: dashed; background: #F9FAFB;"
                    id="emptyState"
                >
                    <div
                        style="font-size: 14px; font-weight: 800; color: #94A3B8; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 2px;"
                    >
                        Archive Vide
                    </div>
                    <h2
                        style="font-size: 20px; font-weight: 800; margin-bottom: 12px; color: var(--onee-blue);"
                    >
                        Aucune estimation enregistrée
                    </h2>
                    <p
                        style="color: var(--w-color-primary-30); margin-bottom: 32px; font-size: 15px;"
                    >
                        Vos simulations apparaîtront ici une fois que vous les
                        aurez sauvegardées depuis le simulateur.
                    </p>
                    <a href="/#simulateurs" class="btn btn-primary"
                        >Nouvelle simulation</a
                    >
                </div>

                <div id="historyList" style="display: none;">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;"
                    >
                        <div
                            style="font-size: 13px; font-weight: 700; color: var(--w-color-primary-30); text-transform: uppercase; letter-spacing: 1px;"
                        >
                            <span id="itemCount">0</span> Enregistrements
                        </div>
                        <button
                            class="btn btn-secondary"
                            id="clearHistory"
                            style="padding: 6px 12px; font-size: 12px; color: var(--w-color-alert);"
                        >
                            Vider l'historique
                        </button>
                    </div>

                    <div class="grid grid-1" style="gap: 16px;" id="itemsGrid">
                        <!-- Items injected here -->
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    function renderHistory() {
        const history = JSON.parse(
            localStorage.getItem("estimation_history") || "[]"
        );
        const emptyState = document.getElementById("emptyState")!;
        const historyList = document.getElementById("historyList")!;
        const itemsGrid = document.getElementById("itemsGrid")!;
        const itemCount = document.getElementById("itemCount")!;

        if (history.length === 0) {
            emptyState.style.display = "block";
            historyList.style.display = "none";
            return;
        }

        emptyState.style.display = "none";
        historyList.style.display = "block";
        itemCount.textContent = history.length.toString();

        itemsGrid.innerHTML = history
            .map((item: any) => {
                const date = new Date(item.date).toLocaleDateString("fr-FR", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                });

                return `
                <div class="bill-card animate-fade-in" style="margin:0">
                    <div style="padding: 24px 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px;">
                        <div style="display: flex; gap: 24px; align-items: center;">
                            <div style="background: var(--onee-blue); color: #fff; width: 52px; height: 52px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; box-shadow: 0 4px 8px rgba(0, 51, 102, 0.1);">
                                ${item.type.toUpperCase()}
                            </div>
                            <div>
                                <div style="font-weight: 800; color: var(--onee-blue); margin-bottom: 4px; font-size: 17px; letter-spacing: -0.3px;">${
                                    item.label
                                }</div>
                                <div style="font-size: 12px; color: var(--w-color-primary-30); font-weight: 600; display: flex; align-items: center; gap: 6px;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                    ${date}
                                </div>
                            </div>
                        </div>
                        
                        <div style="display: flex; align-items: center; gap: 40px;">
                            <div style="text-align: right;">
                                <div style="font-size: 22px; font-weight: 950; color: var(--onee-blue); letter-spacing: -0.5px;">${item.total.toFixed(
                                    2
                                )} <span style="font-size: 14px; font-weight: 700; opacity: 0.7;">DH</span></div>
                                <div style="font-size: 11px; color: var(--w-color-primary-30); font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Audit Énergétique</div>
                            </div>
                            <div style="display: flex; gap: 12px;">
                                <button class="btn btn-secondary btn-sm" onclick="window.location.href='/reclamation?id=${
                                    item.id
                                }'" style="padding: 10px 20px; font-size: 12px; font-weight: 800;">
                                    Rédiger Audit
                                </button>
                                <button class="btn btn-danger btn-icon delete-btn" data-id="${
                                    item.id
                                }" title="Supprimer">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            })
            .join("");

        // Attach delete listeners
        document.querySelectorAll(".delete-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                const newHistory = history.filter(
                    (h: any) => h.id.toString() !== id
                );
                localStorage.setItem(
                    "estimation_history",
                    JSON.stringify(newHistory)
                );
                renderHistory();
            });
        });
    }

    document.getElementById("clearHistory")?.addEventListener("click", () => {
        if (confirm("Êtes-vous sûr de vouloir effacer tout l'historique ?")) {
            localStorage.removeItem("estimation_history");
            renderHistory();
        }
    });

    // Initial render
    renderHistory();
</script>

<style>
    .animate-fade-in {
        opacity: 0;
        transform: translateY(10px);
        animation: fadeInUp 0.4s ease forwards;
    }
</style>
