---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Grilles Tarifaires Électricité - estimation facture"
    activeNav="tarifs"
>
    <section class="section">
        <div class="container">
            <div class="section-header" style="text-align:center">
                <h1 class="section-title">
                    Référentiel <span class="gradient-text">Tarifaire</span>
                </h1>
                <p class="section-subtitle">
                    Catalogue officiel des conditions de vente de l'énergie
                    électrique.
                </p>
            </div>

            <!-- Tab Navigation -->
            <div class="tab-nav" id="tabNav">
                <button class="tab-btn active" data-tab="bt"
                    >Basse Tension</button
                >
                <button class="tab-btn" data-tab="ht">Haute Tension</button>
                <button class="tab-btn" data-tab="tht"
                    >Très Haute Tension</button
                >
                <button class="tab-btn" data-tab="fees">Taxes & Frais</button>
            </div>

            <!-- BT Tab -->
            <div class="tab-panel active" id="bt">
                <div class="bill-card">
                    <div style="padding:40px">
                        <h2
                            style="font-size:18px;font-weight:800;margin-bottom:12px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                        >
                            Tarification Basse Tension (BT)
                        </h2>
                        <p
                            style="font-size:13px;color:var(--w-color-primary-30);margin-bottom:32px;line-height:1.6;font-weight:500"
                        >
                            La structure tarifaire BT repose sur un système de
                            tranches. <br />
                            <strong style="color:var(--onee-blue)"
                                >Règle de facturation :</strong
                            > Pour les volumes supérieurs à 150 kWh/mois, le tarif
                            de la tranche atteinte s'applique à l'intégralité de
                            la consommation commerciale.
                        </p>
                        <table class="bill-table">
                            <thead>
                                <tr>
                                    <th>Poste / Tranche</th>
                                    <th class="amount">Plage de volume (kWh)</th
                                    >
                                    <th class="amount">Prix unit. (DH HT)</th>
                                    <th>Méthode de Calcul</th>
                                </tr>
                            </thead>
                            <tbody style="font-weight:500">
                                <tr>
                                    <td>Tranche 1</td>
                                    <td class="amount">0 — 100</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >0.76356</td
                                    >
                                    <td
                                        ><span class="tag-label"
                                            >Progressif</span
                                        >
                                    </td>
                                </tr>
                                <tr>
                                    <td>Tranche 2</td>
                                    <td class="amount">101 — 150</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >0.90950</td
                                    >
                                    <td
                                        ><span class="tag-label"
                                            >Progressif</span
                                        >
                                    </td>
                                </tr>
                                <tr>
                                    <td>Tranche 3</td>
                                    <td class="amount">151 — 210</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >0.90950</td
                                    >
                                    <td
                                        ><span class="tag-label selective"
                                            >Sélectif</span
                                        >
                                    </td>
                                </tr>
                                <tr>
                                    <td>Tranche 4</td>
                                    <td class="amount">211 — 310</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >0.98950</td
                                    >
                                    <td
                                        ><span class="tag-label selective"
                                            >Sélectif</span
                                        >
                                    </td>
                                </tr>
                                <tr>
                                    <td>Tranche 5</td>
                                    <td class="amount">311 — 510</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >1.17094</td
                                    >
                                    <td
                                        ><span class="tag-label selective"
                                            >Sélectif</span
                                        >
                                    </td>
                                </tr>
                                <tr>
                                    <td>Tranche 6</td>
                                    <td class="amount">&gt; 510</td>
                                    <td
                                        class="amount"
                                        style="color:var(--onee-blue);font-weight:700"
                                        >1.35238</td
                                    >
                                    <td
                                        ><span class="tag-label selective"
                                            >Sélectif</span
                                        >
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- HT Tab -->
            <div class="tab-panel" id="ht">
                <div class="bill-card">
                    <div style="padding:40px">
                        <h2
                            style="font-size:18px;font-weight:800;margin-bottom:12px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                        >
                            Clients Haute Tension (60 kV)
                        </h2>
                        <p
                            style="font-size:13px;color:var(--w-color-primary-30);margin-bottom:32px;font-weight:500"
                        >
                            Tarification industrielle basée sur la durée
                            d'utilisation de la puissance souscrite.
                        </p>
                        <table class="bill-table">
                            <thead>
                                <tr>
                                    <th>Usage</th>
                                    <th class="amount">Prime Fixe (DH/kW/An)</th
                                    >
                                    <th class="amount">Pointe (DH/kWh)</th>
                                    <th class="amount">Pleines (DH/kWh)</th>
                                    <th class="amount">Creuses (DH/kWh)</th>
                                </tr>
                            </thead>
                            <tbody style="font-weight:500">
                                <tr>
                                    <td
                                        ><strong>TLU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >Utilisation &gt; 6000h</small
                                        >
                                    </td>
                                    <td class="amount">2 379.13</td>
                                    <td class="amount">0.8265</td>
                                    <td class="amount">0.6613</td>
                                    <td class="amount">0.6263</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>MU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >3500h - 6000h</small
                                        >
                                    </td>
                                    <td class="amount">952.76</td>
                                    <td class="amount">1.3561</td>
                                    <td class="amount">0.7988</td>
                                    <td class="amount">0.6263</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>CU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >1000h - 3500h</small
                                        >
                                    </td>
                                    <td class="amount">475.46</td>
                                    <td class="amount">1.8101</td>
                                    <td class="amount">0.9388</td>
                                    <td class="amount">0.6567</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>TCU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >Utilisation &lt; 1000h</small
                                        >
                                    </td>
                                    <td class="amount">421.81</td>
                                    <td class="amount">2.0999</td>
                                    <td class="amount">0.9692</td>
                                    <td class="amount">0.6611</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- THT Tab -->
            <div class="tab-panel" id="tht">
                <div class="bill-card">
                    <div style="padding:40px">
                        <h2
                            style="font-size:18px;font-weight:800;margin-bottom:12px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                        >
                            Clients Très Haute Tension (150 - 225 kV)
                        </h2>
                        <p
                            style="font-size:13px;color:var(--w-color-primary-30);margin-bottom:32px;font-weight:500"
                        >
                            Grille tarifaire spécifique aux raccordements de
                            transport d'énergie.
                        </p>
                        <table class="bill-table">
                            <thead>
                                <tr>
                                    <th>Usage</th>
                                    <th class="amount">Prime Fixe (DH/kW/An)</th
                                    >
                                    <th class="amount">Pointe (DH/kWh)</th>
                                    <th class="amount">Pleines (DH/kWh)</th>
                                    <th class="amount">Creuses (DH/kWh)</th>
                                </tr>
                            </thead>
                            <tbody style="font-weight:500">
                                <tr>
                                    <td
                                        ><strong>TLU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >Utilisation &gt; 6000h</small
                                        >
                                    </td>
                                    <td class="amount">2 128.60</td>
                                    <td class="amount">0.7833</td>
                                    <td class="amount">0.6473</td>
                                    <td class="amount">0.6077</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>MU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >3500h - 6000h</small
                                        >
                                    </td>
                                    <td class="amount">852.17</td>
                                    <td class="amount">1.2477</td>
                                    <td class="amount">0.7673</td>
                                    <td class="amount">0.6077</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>CU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >1000h - 3500h</small
                                        >
                                    </td>
                                    <td class="amount">426.08</td>
                                    <td class="amount">1.6454</td>
                                    <td class="amount">0.8924</td>
                                    <td class="amount">0.6348</td>
                                </tr>
                                <tr>
                                    <td
                                        ><strong>TCU</strong>
                                        <small style="display:block;opacity:0.6"
                                            >Utilisation &lt; 1000h</small
                                        >
                                    </td>
                                    <td class="amount">378.00</td>
                                    <td class="amount">1.9088</td>
                                    <td class="amount">0.9213</td>
                                    <td class="amount">0.6391</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Fees Tab -->
            <div class="tab-panel" id="fees">
                <div class="grid grid-2" style="gap:24px">
                    <div class="bill-card">
                        <div style="padding:32px">
                            <h2
                                style="font-size:16px;font-weight:800;margin-bottom:20px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:0.5px"
                            >
                                Droits & Taxes (TVA)
                            </h2>
                            <table class="bill-table">
                                <tbody style="font-weight:500">
                                    <tr>
                                        <td>TVA sur Consommations (RC)</td>
                                        <td
                                            class="amount"
                                            style="color:var(--onee-blue)"
                                            >18%</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>TVA sur Prime Fixe / TPPA</td>
                                        <td
                                            class="amount"
                                            style="color:var(--onee-blue)"
                                            >20%</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>TVA sur Entretien Technique</td>
                                        <td
                                            class="amount"
                                            style="color:var(--onee-blue)"
                                            >20%</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>TVA sur Location de Compteur</td>
                                        <td
                                            class="amount"
                                            style="color:var(--onee-blue)"
                                            >15%</td
                                        >
                                    </tr>
                                    <tr>
                                        <td>Droit de Timbre (Espèce)</td>
                                        <td
                                            class="amount"
                                            style="color:var(--onee-blue)"
                                            >0.25%</td
                                        >
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="bill-card">
                        <div style="padding:32px">
                            <h2
                                style="font-size:16px;font-weight:800;margin-bottom:20px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:0.5px"
                            >
                                Frais d'Abonnement Mensuels
                            </h2>
                            <table class="bill-table">
                                <thead>
                                    <tr>
                                        <th>Calibre du Compteur</th>
                                        <th class="amount">Total Mensuel</th>
                                    </tr>
                                </thead>
                                <tbody style="font-weight:500">
                                    <tr>
                                        <td>Monophasé 2 Fils</td>
                                        <td class="amount">17.42 DH</td>
                                    </tr>
                                    <tr>
                                        <td>Triphasé 4 Fils 5-15A</td>
                                        <td class="amount">33.28 DH</td>
                                    </tr>
                                    <tr>
                                        <td>Triphasé 4 Fils 20-60A</td>
                                        <td class="amount">44.57 DH</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .tab-nav {
        display: flex;
        gap: 8px;
        margin-bottom: 40px;
        padding: 6px;
        background: #f1f5f9;
        border-radius: 8px;
        overflow-x: auto;
        border: 1px solid #e2e8f0;
    }

    .tab-btn {
        padding: 10px 24px;
        border: none;
        background: transparent;
        color: #64748b;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .tab-btn:hover {
        color: var(--onee-blue);
        background: rgba(255, 255, 255, 0.5);
    }

    .tab-btn.active {
        background: #fff;
        color: var(--onee-blue);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
            0 2px 4px -2px rgba(0, 0, 0, 0.1);
    }

    .tab-panel {
        display: none;
        animation: fadeInUp 0.4s ease forwards;
    }

    .tab-panel.active {
        display: block;
    }

    .tag-label {
        font-size: 10px;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: #f1f5f9;
        color: #475569;
    }

    .tag-label.selective {
        background: #fff7ed;
        color: #c2410c;
        border: 1px solid #ffedd5;
    }
</style>

<script>
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            const tabId = btn.dataset.tab;
            if (!tabId) return;

            const targetPanel = document.getElementById(tabId);
            if (!targetPanel) return;

            document
                .querySelectorAll(".tab-btn")
                .forEach((b) => b.classList.remove("active"));
            document
                .querySelectorAll(".tab-panel")
                .forEach((p) => p.classList.remove("active"));

            btn.classList.add("active");
            targetPanel.classList.add("active");
        });
    });
</script>
