---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Simulateur Tarif Général - estimation facture"
    activeNav="general"
>
    <section class="section">
        <div class="container">
            <div class="section-header" style="text-align:center">
                <h1 class="section-title">
                    Tarif Général <span class="gradient-text">HT / THT</span>
                </h1>
                <p class="section-subtitle">
                    Expertise de calcul pour les raccordements Haute et Très
                    Haute Tension.
                </p>
            </div>

            <!-- Wizard Steps -->
            <div class="wizard-steps">
                <div class="wizard-step active" data-step="1">
                    <div class="wizard-step-number">1</div>
                    <span class="wizard-step-label">Configuration</span>
                </div>
                <div class="wizard-step-connector"></div>
                <div class="wizard-step" data-step="2">
                    <div class="wizard-step-number">2</div>
                    <span class="wizard-step-label">Consommation</span>
                </div>
                <div class="wizard-step-connector"></div>
                <div class="wizard-step" data-step="3">
                    <div class="wizard-step-number">3</div>
                    <span class="wizard-step-label">Résultat</span>
                </div>
            </div>

            <!-- Step 1: Configuration -->
            <div class="wizard-panel active" id="step1">
                <div class="bill-card" style="max-width:700px;margin:0 auto">
                    <div style="padding:32px">
                        <h2
                            style="font-size:16px;font-weight:800;margin-bottom:24px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                        >
                            <span style="color:var(--onee-blue);opacity:0.5"
                                >01.</span
                            > Paramètres Techniques
                        </h2>

                        <div class="form-group">
                            <label for="voltageLevel">Palier de Tension</label>
                            <select class="form-select" id="voltageLevel">
                                <option value="">— Sélectionner —</option>
                                <option value="tht"
                                    >THT (150 kV - 225 kV)</option
                                >
                                <option value="ht">HT (60 kV)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="tariffOption"
                                >Option d'Utilisation</label
                            >
                            <select class="form-select" id="tariffOption">
                                <option value="">— Sélectionner —</option>
                                <option value="tlu"
                                    >Très Longue Utilisation (&gt; 6000 h)</option
                                >
                                <option value="mu"
                                    >Moyenne Utilisation (3500 - 6000 h)</option
                                >
                                <option value="cu"
                                    >Courte Utilisation (1000 - 3500 h)</option
                                >
                                <option value="tcu"
                                    >Très Courte Utilisation (&lt; 1000 h)</option
                                >
                            </select>
                        </div>

                        <div
                            class="tariff-preview"
                            id="tariffPreview"
                            style="display:none;padding:16px;margin-bottom:24px;background:#F8FAFC;border-radius:6px;border-left:3px solid var(--onee-blue)"
                        >
                            <div
                                style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:8px;font-weight:600"
                            >
                                <span style="color:var(--w-color-primary-30)"
                                    >Prime Fixe Annuelle :</span
                                >
                                <span
                                    id="prevPrimFixe"
                                    style="color:var(--onee-blue)">—</span
                                >
                            </div>
                            <div
                                style="display:flex;justify-content:space-between;font-size:13px;font-weight:600"
                            >
                                <span style="color:var(--w-color-primary-30)"
                                    >Grille Unitaire (HP/HPL/HC) :</span
                                >
                                <span
                                    id="prevPrices"
                                    style="color:var(--onee-blue)">—</span
                                >
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Régime de Tarification</label>
                            <div style="display:flex;gap:24px;margin-top:8px">
                                <label
                                    style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600;font-size:14px;color:var(--onee-blue)"
                                >
                                    <input
                                        type="radio"
                                        name="mode"
                                        value="general"
                                        checked
                                        id="modeGeneral"
                                        style="width:16px;height:16px"
                                    /> Tarif Général
                                </label>
                                <label
                                    style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600;font-size:14px;color:var(--onee-blue)"
                                >
                                    <input
                                        type="radio"
                                        name="mode"
                                        value="superpointe"
                                        id="modeSuperPointe"
                                        style="width:16px;height:16px"
                                    /> Option Super Pointe
                                </label>
                            </div>
                        </div>

                        <div
                            style="display:flex;gap:16px;justify-content:flex-end;margin-top:40px"
                        >
                            <a href="/" class="btn btn-secondary">Annuler</a>
                            <button
                                class="btn btn-primary"
                                id="gtToStep2"
                                disabled
                                style="padding: 10px 24px">Suivant</button
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: Consumption & Power -->
            <div class="wizard-panel" id="step2">
                <div class="bill-card" style="max-width:750px;margin:0 auto">
                    <div style="padding:32px">
                        <h2
                            style="font-size:16px;font-weight:800;margin-bottom:24px;color:var(--onee-blue);text-transform:uppercase;letter-spacing:1px"
                        >
                            <span style="color:var(--onee-blue);opacity:0.5"
                                >02.</span
                            > Données d'Exploitation
                        </h2>

                        <h3
                            style="font-size:13px;font-weight:800;margin-bottom:16px;color:var(--onee-blue);opacity:0.6;text-transform:uppercase;letter-spacing:0.5px"
                        >
                            Énergie Consommée (kWh)
                        </h3>

                        <!-- Super Pointe field (hidden by default) -->
                        <div
                            class="form-group"
                            id="shpGroup"
                            style="display:none"
                        >
                            <label for="consSHP"
                                >Super Heures de Pointe (SHP)</label
                            >
                            <input
                                type="number"
                                class="form-input"
                                id="consSHP"
                                min="0"
                                value="0"
                            />
                        </div>

                        <div
                            class="form-row-inline"
                            style="margin-bottom: 24px;"
                        >
                            <div class="form-group-inline">
                                <label for="consHP">Pointe (HP)</label>
                                <input
                                    type="number"
                                    class="form-input"
                                    id="consHP"
                                    min="0"
                                    placeholder="kWh"
                                />
                            </div>
                            <div class="form-group-inline">
                                <label for="consHPL">Pleines (HPL)</label>
                                <input
                                    type="number"
                                    class="form-input"
                                    id="consHPL"
                                    min="0"
                                    placeholder="kWh"
                                />
                            </div>
                            <div class="form-group-inline">
                                <label for="consHC">Creuses (HC)</label>
                                <input
                                    type="number"
                                    class="form-input"
                                    id="consHC"
                                    min="0"
                                    placeholder="kWh"
                                />
                            </div>
                        </div>

                        <h3
                            style="font-size:13px;font-weight:800;margin:32px 0 16px;color:var(--onee-blue);opacity:0.6;text-transform:uppercase;letter-spacing:0.5px"
                        >
                            Puissances Appelées vs Souscrites (kW)
                        </h3>

                        <!-- Super Pointe power fields -->
                        <div id="spPowerGroup" style="display:none">
                            <div
                                class="grid grid-2"
                                style="margin-bottom:16px;gap:24px"
                            >
                                <div class="form-group">
                                    <label for="psSHP">PS Super Pointe</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="psSHP"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="paSHP">PA Super Pointe</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="paSHP"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                            </div>
                            <div
                                class="grid grid-2"
                                style="margin-bottom:16px;gap:24px"
                            >
                                <div class="form-group">
                                    <label for="ps1">PS Pointe</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="ps1"
                                        min="0"
                                        placeholder="PS1"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="pa1">PA Pointe</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="pa1"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                            </div>
                            <div
                                class="grid grid-2"
                                style="margin-bottom:16px;gap:24px"
                            >
                                <div class="form-group">
                                    <label for="ps2">PS Pleines</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="ps2"
                                        min="0"
                                        placeholder="PS2"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="pa2">PA Pleines</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="pa2"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                            </div>
                            <div class="grid grid-2" style="gap:24px">
                                <div class="form-group">
                                    <label for="ps3">PS Creuses</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="ps3"
                                        min="0"
                                        placeholder="PS3"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="pa3">PA Creuses</label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="pa3"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                            </div>
                        </div>

                        <!-- General power fields -->
                        <div id="genPowerGroup">
                            <div class="grid grid-2" style="gap:24px">
                                <div class="form-group">
                                    <label for="puissanceSouscrite"
                                        >Puissance Souscrite Annuelle (PS)
                                    </label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="puissanceSouscrite"
                                        min="0"
                                        placeholder="kW"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="puissanceAppelee"
                                        >Puissance Maximale Appelée (PA)
                                    </label>
                                    <input
                                        type="number"
                                        class="form-input"
                                        id="puissanceAppelee"
                                        min="0"
                                        value="0"
                                    />
                                </div>
                            </div>
                        </div>

                        <div
                            class="grid grid-2"
                            style="margin-top:32px;gap:24px"
                        >
                            <div class="form-group" style="margin-bottom:0">
                                <label for="cosPhi"
                                    >Facteur de Puissance (cos φ)
                                    <span class="form-hint"
                                        >Seuil contractuel : <span
                                            id="cosPhiMin">0.80</span
                                        >
                                    </span>
                                </label>
                                <input
                                    type="number"
                                    class="form-input"
                                    id="cosPhi"
                                    min="0"
                                    max="1"
                                    step="0.01"
                                    value="0.90"
                                />
                            </div>
                            <div
                                style="display:flex;align-items:center;padding-top:20px"
                            >
                                <label
                                    style="display:flex;align-items:center;gap:10px;cursor:pointer;font-weight:600;font-size:14px;color:var(--onee-blue)"
                                >
                                    <input
                                        type="checkbox"
                                        id="firstSixMonths"
                                        style="width:18px;height:18px"
                                    />
                                    Période de mise en service (6 premiers mois)
                                </label>
                            </div>
                        </div>

                        <div
                            style="display:flex;gap:16px;justify-content:flex-end;margin-top:48px"
                        >
                            <button class="btn btn-secondary" id="gtBackToStep1"
                                >Retour</button
                            >
                            <button
                                class="btn btn-primary"
                                id="gtCalculateBtn"
                                style="padding: 10px 24px"
                                >Générer le rapport</button
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 3: Results -->
            <div class="wizard-panel" id="step3">
                <div class="bill-card" style="max-width:850px;margin:0 auto">
                    <div style="padding:40px">
                        <div
                            style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;border-bottom:2px solid #F1F5F9;padding-bottom:24px"
                        >
                            <div>
                                <h2
                                    style="font-size:22px;font-weight:800;color:var(--onee-blue)"
                                >
                                    Rapport d'Expertise HT/THT
                                </h2>
                                <p
                                    style="font-size:13px;color:var(--w-color-primary-30);margin-top:6px;font-weight:600"
                                    id="gtResultMeta"
                                >
                                </p>
                            </div>
                            <div style="text-align:right">
                                <div
                                    style="font-size:12px;font-weight:800;color:var(--onee-blue);opacity:0.5;text-transform:uppercase;letter-spacing:1px"
                                >
                                    Analyse Industrielle
                                </div>
                            </div>
                        </div>

                        <div
                            class="result-total"
                            style="text-align:center;padding:32px;margin-bottom:40px;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:12px"
                        >
                            <p
                                style="font-size:13px;font-weight:700;color:var(--w-color-primary-30);margin-bottom:8px;text-transform:uppercase;letter-spacing:1px"
                            >
                                Sous-total mensuel Hors Taxes
                            </p>
                            <div
                                class="result-amount"
                                style="font-size:48px;font-weight:900;color:var(--onee-blue)"
                            >
                                <span id="gtTotalAmount">0.00</span>
                                <span style="font-size:20px;margin-left:4px"
                                    >DH</span
                                >
                            </div>
                        </div>

                        <table class="bill-table">
                            <thead>
                                <tr>
                                    <th>Composante du Tarif</th>
                                    <th>Description des Postes</th>
                                    <th class="amount">Montant HT</th>
                                </tr>
                            </thead>
                            <tbody id="gtResultBody" style="font-weight:500"
                            ></tbody>
                            <tfoot>
                                <tr>
                                    <td
                                        colspan="2"
                                        style="font-weight:900;padding:18px"
                                        >TOTAL NET HORS TAXES</td
                                    >
                                    <td
                                        class="amount"
                                        style="font-weight:900;padding:18px;font-size:18px"
                                        id="gtTotalHT">0.00</td
                                    >
                                </tr>
                            </tfoot>
                        </table>

                        <div
                            style="margin-top:40px;padding:20px;background:#F1F5F9;border:1px solid #E2E8F0;border-radius:8px;text-align:center"
                        >
                            <p
                                style="font-size:12px;color:var(--w-color-primary-20);font-weight:600"
                            >
                                Note : Les montants HT sont calculés selon la
                                structure tarifaire en vigueur. La TVA de 20%
                                ainsi que les éventuelles taxes locales ne sont
                                pas incluses dans ce rapport d'analyse HT.
                            </p>
                        </div>

                        <div
                            style="display:flex;gap:16px;justify-content:center;margin-top:48px;flex-wrap:wrap"
                            class="no-print"
                        >
                            <button class="btn btn-secondary" id="gtBackToStep2"
                                >Réajuster</button
                            >
                            <button
                                class="btn btn-primary"
                                id="gtSaveBtn"
                                style="padding: 10px 24px"
                            >
                                Enregistrer
                            </button>
                            <button
                                class="btn btn-primary"
                                id="exportPDF"
                                style="padding: 10px 24px; background: #1E293B; border-color: #1E293B"
                            >
                                Télécharger l'audit
                            </button>
                            <button
                                class="btn btn-primary"
                                onclick="window.print()"
                                style="padding: 10px 24px; background: #1E293B; border-color: #1E293B"
                            >
                                Imprimer l'audit
                            </button>
                            <button class="btn btn-secondary" id="gtNewCalc"
                                >Nouvelle simulation</button
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .wizard-panel {
        display: none;
    }
    .wizard-panel.active {
        display: block;
        animation: fadeInUp 0.4s ease forwards;
    }
    input[type="radio"],
    input[type="checkbox"] {
        accent-color: var(--onee-blue);
    }
</style>

<script>
    // Tariff data
    type TariffRates = { pf: number; hp: number; hpl: number; hc: number };
    const TARIFFS: Record<string, Record<string, TariffRates>> = {
        tht: {
            tlu: { pf: 2128.6, hp: 0.7833, hpl: 0.6473, hc: 0.6077 },
            mu: { pf: 852.17, hp: 1.2477, hpl: 0.7673, hc: 0.6077 },
            cu: { pf: 426.08, hp: 1.6454, hpl: 0.8924, hc: 0.6348 },
            tcu: { pf: 378.0, hp: 1.9088, hpl: 0.9213, hc: 0.6391 },
        },
        ht: {
            tlu: { pf: 2379.13, hp: 0.8265, hpl: 0.6613, hc: 0.6263 },
            mu: { pf: 952.76, hp: 1.3561, hpl: 0.7988, hc: 0.6263 },
            cu: { pf: 475.46, hp: 1.8101, hpl: 0.9388, hc: 0.6567 },
            tcu: { pf: 421.81, hp: 2.0999, hpl: 0.9692, hc: 0.6611 },
        },
    };

    function round2Gen(n: number): number {
        return Math.round((n + Number.EPSILON) * 100) / 100;
    }
    function fmtGen(n: number): string {
        return n.toFixed(2);
    }

    const voltageLevel = document.getElementById("voltageLevel") as any;
    const tariffOption = document.getElementById("tariffOption") as any;
    const tariffPreview = document.getElementById("tariffPreview") as any;
    const modeGeneral = document.getElementById("modeGeneral") as any;
    const modeSuperPointe = document.getElementById("modeSuperPointe") as any;

    function goToStepGen(step: number): void {
        document
            .querySelectorAll(".wizard-panel")
            .forEach((p) => p.classList.remove("active"));
        document.getElementById("step" + step)!.classList.add("active");
        document.querySelectorAll<HTMLElement>(".wizard-step").forEach((s) => {
            const sn = parseInt(s.dataset.step || "0");
            s.classList.remove("active", "completed");
            if (sn < step) s.classList.add("completed");
            if (sn === step) s.classList.add("active");
        });
    }

    function validateStep1Gen(): void {
        const btn = document.querySelector<HTMLButtonElement>("#gtToStep2");
        if (btn) btn.disabled = !(voltageLevel.value && tariffOption.value);
    }

    function updatePreviewGen(): void {
        if (voltageLevel.value && tariffOption.value) {
            const t = TARIFFS[voltageLevel.value][tariffOption.value];
            document.getElementById("prevPrimFixe")!.textContent =
                t.pf + " DH kW/An";
            document.getElementById(
                "prevPrices"
            )!.textContent = `${t.hp} / ${t.hpl} / ${t.hc} DH/kWh`;
            tariffPreview.style.display = "block";
        } else {
            tariffPreview.style.display = "none";
        }
    }

    voltageLevel.addEventListener("change", () => {
        validateStep1Gen();
        updatePreviewGen();
    });
    tariffOption.addEventListener("change", () => {
        validateStep1Gen();
        updatePreviewGen();
    });

    // Mode toggle
    document
        .querySelectorAll<HTMLInputElement>('input[name="mode"]')
        .forEach((r) => {
            r.addEventListener("change", () => {
                const isSP = modeSuperPointe.checked;
                (
                    document.getElementById("shpGroup") as HTMLElement
                ).style.display = isSP ? "block" : "none";
                (
                    document.getElementById("spPowerGroup") as HTMLElement
                ).style.display = isSP ? "block" : "none";
                (
                    document.getElementById("genPowerGroup") as HTMLElement
                ).style.display = isSP ? "none" : "block";
                document.getElementById("cosPhiMin")!.textContent = isSP
                    ? "0.90"
                    : "0.80";
            });
        });

    // Navigation
    document
        .getElementById("gtToStep2")!
        .addEventListener("click", () => goToStepGen(2));
    document
        .getElementById("gtBackToStep1")!
        .addEventListener("click", () => goToStepGen(1));
    document
        .getElementById("gtBackToStep2")!
        .addEventListener("click", () => goToStepGen(2));
    document.getElementById("gtNewCalc")!.addEventListener("click", () => {
        voltageLevel.value = "";
        tariffOption.value = "";
        tariffPreview.style.display = "none";
        validateStep1Gen();
        goToStepGen(1);
    });

    // Calculate
    document.getElementById("gtCalculateBtn")!.addEventListener("click", () => {
        const t = TARIFFS[voltageLevel.value][tariffOption.value];
        const isSP = modeSuperPointe.checked;
        const cosPhi =
            parseFloat(
                (document.getElementById("cosPhi") as HTMLInputElement).value
            ) || 0.9;
        const isFirst6 = (
            document.getElementById("firstSixMonths") as HTMLInputElement
        ).checked;
        const cosPhiThreshold = isSP ? 0.9 : 0.8;

        const consHP =
            parseFloat(
                (document.getElementById("consHP") as HTMLInputElement).value
            ) || 0;
        const consHPL =
            parseFloat(
                (document.getElementById("consHPL") as HTMLInputElement).value
            ) || 0;
        const consHC =
            parseFloat(
                (document.getElementById("consHC") as HTMLInputElement).value
            ) || 0;

        let rc: number,
            rp: number,
            rdps: number,
            majCosPhi: number,
            totalHT: number;
        const rows: Array<{
            label: string;
            detail: string;
            amount: number;
        }> = [];

        if (isSP) {
            // Super Pointe
            const consSHP =
                parseFloat(
                    (document.getElementById("consSHP") as HTMLInputElement)
                        .value
                ) || 0;
            const psSHP =
                parseFloat(
                    (document.getElementById("psSHP") as HTMLInputElement).value
                ) || 0;
            const ps1 =
                parseFloat(
                    (document.getElementById("ps1") as HTMLInputElement).value
                ) || 0;
            const ps2 =
                parseFloat(
                    (document.getElementById("ps2") as HTMLInputElement).value
                ) || 0;
            const ps3 =
                parseFloat(
                    (document.getElementById("ps3") as HTMLInputElement).value
                ) || 0;
            const paSHP =
                parseFloat(
                    (document.getElementById("paSHP") as HTMLInputElement).value
                ) || 0;
            const pa1 =
                parseFloat(
                    (document.getElementById("pa1") as HTMLInputElement).value
                ) || 0;
            const pa2 =
                parseFloat(
                    (document.getElementById("pa2") as HTMLInputElement).value
                ) || 0;
            const pa3 =
                parseFloat(
                    (document.getElementById("pa3") as HTMLInputElement).value
                ) || 0;

            const pSHP = round2Gen(t.hp * 1.2);
            const rcSHP = round2Gen(pSHP * consSHP);
            const rcHP = round2Gen(t.hp * consHP);
            const rcHPL = round2Gen(t.hpl * consHPL);
            const rcHC = round2Gen(t.hc * consHC);
            rc = round2Gen(rcSHP + rcHP + rcHPL + rcHC);

            const rpBase = t.pf / 12;
            rp = round2Gen(
                rpBase *
                    (psSHP +
                        0.8 * (ps1 - psSHP) +
                        0.6 * (ps2 - ps1) +
                        0.4 * (ps3 - ps2))
            );

            rdps = 0;
            if (!isFirst6) {
                const d0 = Math.max(0, paSHP - psSHP);
                const d1 = Math.max(0, pa1 - ps1);
                const d2 = Math.max(0, pa2 - ps2);
                const d3 = Math.max(0, pa3 - ps3);
                if (d0 + d1 + d2 + d3 > 0) {
                    rdps = round2Gen(
                        1.5 * rpBase * (d0 + 0.8 * d1 + 0.6 * d2 + 0.4 * d3)
                    );
                }
            }

            rows.push({
                label: "Maturité Super Pointe",
                detail: `${consSHP} kWh × ${pSHP} DH`,
                amount: rcSHP,
            });
            rows.push({
                label: "Maturité Heures Pointe",
                detail: `${consHP} kWh × ${t.hp} DH`,
                amount: rcHP,
            });
            rows.push({
                label: "Maturité Heures Pleines",
                detail: `${consHPL} kWh × ${t.hpl} DH`,
                amount: rcHPL,
            });
            rows.push({
                label: "Maturité Heures Creuses",
                detail: `${consHC} kWh × ${t.hc} DH`,
                amount: rcHC,
            });
        } else {
            // General
            const rcHP = round2Gen(t.hp * consHP);
            const rcHPL = round2Gen(t.hpl * consHPL);
            const rcHC = round2Gen(t.hc * consHC);
            rc = round2Gen(rcHP + rcHPL + rcHC);

            const ps =
                parseFloat(
                    (
                        document.getElementById(
                            "puissanceSouscrite"
                        ) as HTMLInputElement
                    ).value
                ) || 0;
            const pa =
                parseFloat(
                    (
                        document.getElementById(
                            "puissanceAppelee"
                        ) as HTMLInputElement
                    ).value
                ) || 0;
            rp = round2Gen((t.pf / 12) * ps);

            rdps = 0;
            if (!isFirst6 && pa > ps) {
                rdps = round2Gen(1.5 * (t.pf / 12) * (pa - ps));
            }

            rows.push({
                label: "Maturité Heures Pointe",
                detail: `${consHP} kWh × ${t.hp} DH`,
                amount: rcHP,
            });
            rows.push({
                label: "Maturité Heures Pleines",
                detail: `${consHPL} kWh × ${t.hpl} DH`,
                amount: rcHPL,
            });
            rows.push({
                label: "Maturité Heures Creuses",
                detail: `${consHC} kWh × ${t.hc} DH`,
                amount: rcHC,
            });
        }

        majCosPhi = 0;
        if (cosPhi < cosPhiThreshold) {
            const ratio = (cosPhiThreshold - cosPhi) / cosPhiThreshold;
            majCosPhi = round2Gen((rc + rp + rdps) * ratio);
        }

        totalHT = round2Gen(rc + rp + rdps + majCosPhi);

        rows.push({
            label: "Redevance de Puissance (RP)",
            detail: "Prime fixe mensuelle",
            amount: rp,
        });
        if (rdps > 0) {
            rows.push({
                label: "Dépassement de Puissance",
                detail: "Pénalité RDPS",
                amount: rdps,
            });
        }
        if (majCosPhi > 0) {
            rows.push({
                label: "Majoration Cos φ",
                detail: `Facteur : ${cosPhi} (Seuil : ${cosPhiThreshold})`,
                amount: majCosPhi,
            });
        }

        // Render
        const body = document.getElementById("gtResultBody")!;
        body.innerHTML = rows
            .map(
                (r) => `
            <tr>
                <td>${r.label}</td>
                <td style="font-size:12px;opacity:0.7">${r.detail}</td>
                <td class="amount">${fmtGen(r.amount)}</td>
            </tr>
        `
            )
            .join("");

        document.getElementById("gtTotalAmount")!.textContent = fmtGen(totalHT);
        document.getElementById("gtTotalHT")!.textContent = fmtGen(totalHT);

        // Meta
        const vLabel = voltageLevel.options[voltageLevel.selectedIndex].text;
        const oLabel = tariffOption.options[tariffOption.selectedIndex].text;
        document.getElementById(
            "gtResultMeta"
        )!.textContent = `${vLabel} • ${oLabel} • cos φ ${cosPhi}`;

        // Save logic
        const saveBtn = document.getElementById("gtSaveBtn")!;
        (saveBtn as any).onclick = () => {
            const history = JSON.parse(
                localStorage.getItem("estimation_history") || "[]"
            );
            const entry = {
                id: Date.now(),
                type: "general",
                date: new Date().toISOString(),
                label: `Tarif HT/THT - ${vLabel}`,
                total: totalHT,
                details: {
                    voltage: voltageLevel.value,
                    option: tariffOption.value,
                    mode: isSP ? "superpointe" : "general",
                    totalHT,
                },
            };
            history.unshift(entry);
            localStorage.setItem("estimation_history", JSON.stringify(history));
            saveBtn.setAttribute("disabled", "true");
            saveBtn.textContent = "Enregistré";
            saveBtn.style.opacity = "0.5";
        };

        goToStepGen(3);
    });

    // Export PDF
    document
        .getElementById("exportPDF")
        ?.addEventListener("click", async () => {
            const element = document.getElementById("step3")!;
            const btn = document.getElementById(
                "exportPDF"
            ) as HTMLButtonElement;
            const originalText = btn.textContent;

            btn.disabled = true;
            btn.textContent = "Génération...";

            try {
                const loadHtml2Pdf = async () => {
                    // @ts-ignore
                    if (window.html2pdf) {
                        // @ts-ignore
                        return window.html2pdf;
                    }

                    await new Promise<void>((resolve, reject) => {
                        const existing = document.querySelector(
                            'script[data-html2pdf="1"]'
                        ) as HTMLScriptElement | null;

                        if (existing) {
                            existing.addEventListener("load", () => resolve(), {
                                once: true,
                            });
                            existing.addEventListener(
                                "error",
                                () => reject(new Error("Chargement html2pdf impossible")),
                                { once: true }
                            );
                            return;
                        }

                        const script = document.createElement("script");
                        script.src =
                            "https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js";
                        script.dataset.html2pdf = "1";
                        script.onload = () => resolve();
                        script.onerror = () =>
                            reject(new Error("Chargement html2pdf impossible"));
                        document.head.appendChild(script);
                    });

                    // @ts-ignore
                    if (!window.html2pdf) {
                        throw new Error("html2pdf indisponible");
                    }

                    // @ts-ignore
                    return window.html2pdf;
                };

                const html2pdf = await loadHtml2Pdf();

                // Extract data
                const htAmount = document.getElementById("gtTotalAmount")!.textContent;
                const metaStr = document.getElementById("gtResultMeta")!.textContent;
                const trancheRowsHtml = document.getElementById("gtResultBody")!.innerHTML;

                // Create a temporary container
                const container = document.createElement("div");
                container.style.position = "fixed";
                container.style.left = "0";
                container.style.top = "0";
                container.style.width = "210mm";
                container.style.zIndex = "-9999";
                container.style.background = "white";
                container.style.visibility = "visible";

                container.innerHTML = `
                <div style="padding: 15mm; font-family: Arial, sans-serif; color: #333; line-height: 1.4; background: white;">
                    <!-- EN-TETE / HEADER -->
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; border-bottom: 2px solid #003366; padding-bottom: 10px;">
                        <div style="width: 70%;">
                            <h1 style="margin: 0; color: #003366; font-size: 22px; font-weight: bold;">OFFICE NATIONAL DE L'ÉLECTRICITÉ</h1>
                            <p style="margin: 2px 0; font-size: 14px; font-weight: bold;">Branche Électricité - Expertise Industrielle</p>
                            <p style="margin: 10px 0 0; font-size: 10px; color: #666;">Document technique - Simulation HT/THT</p>
                        </div>
                        <div style="text-align: right;">
                            <div style="background: #f1f5f9; padding: 10px; border: 1px solid #cbd5e1; border-radius: 4px;">
                                <h2 style="margin: 0; font-size: 12px; color: #003366;">TOTAL ESTIMÉ HT</h2>
                                <p style="margin: 5px 0 0; font-size: 20px; font-weight: 900; color: #d32f2f;">${htAmount} DH</p>
                            </div>
                        </div>
                    </div>

                    <!-- INFOS CLIENT / CONTRACT -->
                    <div style="display: flex; gap: 20px; margin-bottom: 30px;">
                        <div style="flex: 1.5; border: 1px solid #cbd5e1; padding: 12px; border-radius: 4px;">
                            <div style="font-size: 9px; font-weight: bold; color: #64748b; margin-bottom: 5px; text-transform: uppercase;">Paramètres du Contrat</div>
                            <div style="font-size: 12px; color: #1e293b; font-weight: bold;">${metaStr}</div>
                        </div>
                        <div style="flex: 1; border: 1px solid #cbd5e1; padding: 12px; border-radius: 4px;">
                            <div style="font-size: 9px; font-weight: bold; color: #64748b; margin-bottom: 5px; text-transform: uppercase;">Référence Expertise</div>
                            <div style="font-size: 12px; color: #1e293b;">Date: ${new Date().toLocaleDateString('fr-FR')}</div>
                            <div style="font-size: 12px; color: #1e293b;">Option: Moyenne/Haute Tension</div>
                        </div>
                    </div>

                    <!-- TABLEAU DETAIL -->
                    <div style="margin-bottom: 30px;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                            <thead>
                                <tr style="background: #003366; color: white;">
                                    <th style="padding: 10px; text-align: left; border: 1px solid #003366;">COMPOSANTE DU TARIF</th>
                                    <th style="padding: 10px; text-align: left; border: 1px solid #003366;">DÉTAIL DU CALCUL</th>
                                    <th style="padding: 10px; text-align: right; border: 1px solid #003366;">MONTANT H.T</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${trancheRowsHtml.replace(/<tr/g, '<tr style="border-bottom: 1px solid #eee;"').replace(/<td/g, '<td style="padding: 8px 10px;"')}
                            </tbody>
                        </table>
                    </div>

                    <!-- SYNTHESE HT -->
                    <div style="display: flex; justify-content: flex-end;">
                        <div style="width: 50%;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
                                <tr style="background: #003366; color: white;">
                                    <td style="padding: 12px; font-weight: bold;">TOTAL NET À PAYER HT</td>
                                    <td style="padding: 12px; text-align: right; font-weight: 900; font-size: 18px;">${htAmount} DH</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- FOOTER INFO -->
                    <div style="margin-top: 60px; border-top: 1px dashed #cbd5e1; padding-top: 15px; font-size: 9px; color: #64748b; text-align: center;">
                        <p>Document généré par l'Expertise de Facture Électrique Industrielle Maroc - ${new Date().toLocaleDateString('fr-FR')}</p>
                        <p>Note : Cette expertise est une simulation HT. La TVA (18%/20%) et les taxes locales ne sont pas incluses.</p>
                    </div>
                </div>
                `;

                document.body.appendChild(container);

                const opt = {
                    margin: 0,
                    filename: `expertise-ht-tht-${new Date().getTime()}.pdf`,
                    image: { type: "jpeg", quality: 0.98 },
                    html2canvas: {
                        scale: 2,
                        useCORS: true,
                        backgroundColor: '#ffffff',
                        logging: false
                    },
                    jsPDF: {
                        unit: "mm",
                        format: "a4",
                        orientation: "portrait"
                    },
                };

                setTimeout(() => {
                    html2pdf()
                        .set(opt)
                        .from(container)
                        .save()
                        .then(() => {
                            document.body.removeChild(container);
                        })
                        .finally(() => {
                            btn.disabled = false;
                            btn.textContent = originalText;
                        });
                }, 1000); // 1 second rendering safety delay
            } catch (error) {
                console.error(error);
                alert(
                    "La génération PDF a échoué. Veuillez réessayer ou utiliser l'impression."
                );
                btn.disabled = false;
                btn.textContent = originalText;
            }
        });

    export {};
</script>
