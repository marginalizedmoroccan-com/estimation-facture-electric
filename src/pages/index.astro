---
import Layout from "../layouts/Layout.astro";
---

<Layout title="estimation facture - Simulateur Électricité" activeNav="home">
	<!-- Hero Section -->
	<section class="hero">
		<div class="container">
			<div class="hero-content">
				<div
					class="hero-badge"
					style="animation: fadeInUp 0.5s ease forwards;"
				>
					<span>⚡ Le simulateur intelligent</span>
				</div>
				<h1
					class="hero-title"
					style="animation: fadeInUp 0.6s ease forwards; animation-delay: 0.1s;"
				>
					Estimez votre <span class="gradient-text">facture</span>
					<br /> d'électricité en un clic.
				</h1>
				<p
					class="hero-subtitle"
					style="animation: fadeInUp 0.7s ease forwards; animation-delay: 0.2s;"
				>
					L'outil le plus précis pour calculer vos consommations Basse
					Tension et Tarif Général, basé sur les grilles tarifaires
					officielles.
				</p>
				<div
					class="hero-actions"
					style="animation: fadeInUp 0.8s ease forwards; animation-delay: 0.3s;"
				>
					<a href="#simulateurs" class="btn btn-primary btn-lg">
						Commencer l'estimation
						<svg
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							><path
								d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"></path>
						</svg>
					</a>
					<a href="/tarifs" class="btn btn-secondary btn-lg"
						>Voir les tarifs</a
					>
				</div>
			</div>
			<div class="hero-visual animate-fade-in delay-3">
				<div class="hero-card glass-card">
					<div class="hero-card-header">
						<span class="hero-card-dot" style="background:#EE5253"
						></span>
						<span class="hero-card-dot" style="background:#FF9F43"
						></span>
						<span class="hero-card-dot" style="background:#10AC84"
						></span>
					</div>
					<div class="hero-card-body">
						<div class="hero-stat">
							<span class="hero-stat-label">Consommation</span>
							<span class="hero-stat-value gradient-text"
								>250 kWh</span
							>
						</div>
						<div class="hero-stat">
							<span class="hero-stat-label">Montant estimé</span>
							<span
								class="hero-stat-value"
								style="color: var(--onee-gold)">312.45 DH</span
							>
						</div>
						<div class="hero-bar-chart">
							<div class="hero-bar" style="height: 40%">
								<span>T1</span>
							</div>
							<div class="hero-bar" style="height: 55%">
								<span>T2</span>
							</div>
							<div class="hero-bar active" style="height: 75%">
								<span>T3</span>
							</div>
							<div class="hero-bar" style="height: 60%">
								<span>T4</span>
							</div>
							<div class="hero-bar" style="height: 45%">
								<span>T5</span>
							</div>
							<div class="hero-bar" style="height: 30%">
								<span>T6</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Stats Section -->
	<section class="stats-section">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-item animate-fade-in-up delay-1">
					<div class="stat-number gradient-text">6</div>
					<div class="stat-label">Tranches tarifaires</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-2">
					<div class="stat-number gradient-text">4</div>
					<div class="stat-label">Types de clients</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-3">
					<div class="stat-number gradient-text">3</div>
					<div class="stat-label">Simulateurs</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-4">
					<div class="stat-number gradient-text">100%</div>
					<div class="stat-label">Gratuit</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Simulators Section -->
	<section class="section" id="simulateurs">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">
					Choisissez votre <span class="gradient-text"
						>simulateur</span>
				</h2>
				<p class="section-subtitle">
					Sélectionnez le type de client correspondant à votre
					abonnement
				</p>
			</div>

			<div class="cards-grid">
				<!-- BT Card -->
				<a
					href="/simulateur-bt"
					class="sim-card glass-card animate-fade-in-up delay-1"
				>
					<div
						class="sim-card-icon"
						style="background: linear-gradient(135deg, #0ABDE3, #0A5FA8);"
					>
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><path
								d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"
							></path><polyline points="9 22 9 12 15 12 15 22"
							></polyline>
						</svg>
					</div>
					<h3 class="sim-card-title">Basse Tension (BT)</h3>
					<p class="sim-card-desc">
						Clients résidentiels et commerciaux. Tarifs domestique,
						patenté et force motrice.
					</p>
					<div class="sim-card-tags">
						<span class="tag">Domestique</span>
						<span class="tag">Patenté</span>
						<span class="tag">Force Motrice</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="20"
							height="20"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>

				<!-- General Tariff Card -->
				<a
					href="/simulateur-general"
					class="sim-card glass-card animate-fade-in-up delay-2"
				>
					<div
						class="sim-card-icon"
						style="background: linear-gradient(135deg, #D4A843, #C49530);"
					>
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><rect x="2" y="7" width="20" height="14" rx="2"
							></rect><path
								d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"
							></path><line x1="12" y1="12" x2="12" y2="16"
							></line>
						</svg>
					</div>
					<h3 class="sim-card-title">Tarif Général (HT/THT)</h3>
					<p class="sim-card-desc">
						Grands comptes haute et très haute tension. Options TLU,
						MU, CU, TCU.
					</p>
					<div class="sim-card-tags">
						<span class="tag">60 kV</span>
						<span class="tag">150-225 kV</span>
						<span class="tag">Super Pointe</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="20"
							height="20"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>

				<!-- Tarifs Card -->
				<a
					href="/tarifs"
					class="sim-card glass-card animate-fade-in-up delay-3"
				>
					<div
						class="sim-card-icon"
						style="background: linear-gradient(135deg, #10AC84, #0E8A6A);"
					>
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><path
								d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
							></path><polyline points="14 2 14 8 20 8"
							></polyline><line x1="16" y1="13" x2="8" y2="13"
							></line><line x1="16" y1="17" x2="8" y2="17"></line>
						</svg>
					</div>
					<h3 class="sim-card-title">Grilles Tarifaires</h3>
					<p class="sim-card-desc">
						Consultez tous les tarifs en vigueur, prix unitaires et
						redevances fixes.
					</p>
					<div class="sim-card-tags">
						<span class="tag">Tarifs BT</span>
						<span class="tag">Tarifs HT</span>
						<span class="tag">Redevances</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="20"
							height="20"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="section how-section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">
					Comment ça <span class="gradient-text">fonctionne</span>
				</h2>
				<p class="section-subtitle">Un processus simple en 3 étapes</p>
			</div>
			<div class="steps-grid">
				<div class="step-item animate-fade-in-up delay-1">
					<div class="step-number">1</div>
					<h3>Sélectionnez</h3>
					<p>
						Choisissez votre type de tarif et de compteur parmi les
						options disponibles
					</p>
				</div>
				<div class="step-connector"></div>
				<div class="step-item animate-fade-in-up delay-2">
					<div class="step-number">2</div>
					<h3>Saisissez</h3>
					<p>
						Entrez votre consommation en kWh et la période de
						facturation
					</p>
				</div>
				<div class="step-connector"></div>
				<div class="step-item animate-fade-in-up delay-3">
					<div class="step-number">3</div>
					<h3>Obtenez</h3>
					<p>
						Visualisez le détail complet de votre facture estimée
						instantanément
					</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding: 80px 0 40px;
		position: relative;
		overflow: hidden;
	}

	.hero::before {
		content: "";
		position: absolute;
		top: -50%;
		left: -20%;
		width: 60%;
		height: 200%;
		background: radial-gradient(
			ellipse,
			rgba(10, 189, 227, 0.08) 0%,
			transparent 70%
		);
		pointer-events: none;
	}

	.hero .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.hero-badge {
		display: inline-flex;
		padding: 6px 16px;
		background: rgba(10, 189, 227, 0.1);
		border: 1px solid rgba(10, 189, 227, 0.3);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		color: var(--onee-cyan);
		margin-bottom: 20px;
	}

	.hero-title {
		font-size: 52px;
		font-weight: 900;
		line-height: 1.1;
		margin-bottom: 20px;
		letter-spacing: -1px;
	}

	.hero-subtitle {
		font-size: 17px;
		color: var(--w-color-primary-20);
		line-height: 1.7;
		margin-bottom: 32px;
		max-width: 500px;
	}

	.hero-actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
	}

	.hero-visual {
		display: flex;
		justify-content: flex-end;
	}

	.hero-card {
		width: 340px;
		padding: 0;
		overflow: hidden;
	}

	.hero-card-header {
		display: flex;
		gap: 6px;
		padding: 12px 16px;
		border-bottom: 1px solid var(--onee-card-border);
	}

	.hero-card-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.hero-card-body {
		padding: 20px;
	}

	.hero-stat {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 16px;
	}

	.hero-stat-label {
		font-size: 13px;
		color: var(--w-color-primary-30);
	}

	.hero-stat-value {
		font-size: 20px;
		font-weight: 800;
	}

	.hero-bar-chart {
		display: flex;
		align-items: flex-end;
		gap: 8px;
		height: 100px;
		padding-top: 16px;
		border-top: 1px solid var(--onee-card-border);
	}

	.hero-bar {
		flex: 1;
		background: linear-gradient(
			180deg,
			rgba(10, 189, 227, 0.3),
			rgba(10, 189, 227, 0.1)
		);
		border-radius: 4px 4px 0 0;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding-bottom: 6px;
		transition: all 0.3s;
	}

	.hero-bar.active {
		background: linear-gradient(
			180deg,
			var(--onee-cyan),
			rgba(10, 189, 227, 0.4)
		);
	}

	.hero-bar span {
		font-size: 10px;
		font-weight: 600;
		color: var(--w-color-primary-20);
	}

	.hero-bar.active span {
		color: #fff;
	}

	/* Stats */
	.stats-section {
		padding: 40px 0;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.stat-item {
		text-align: center;
		padding: 24px;
		border: 1px solid var(--onee-card-border);
		border-radius: var(--w-lg-radius);
		background: rgba(15, 31, 51, 0.4);
	}

	.stat-number {
		font-size: 36px;
		font-weight: 900;
	}

	.stat-label {
		font-size: 14px;
		color: var(--w-color-primary-20);
		margin-top: 4px;
	}

	/* Cards Grid */
	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.sim-card {
		padding: 28px;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.sim-card-icon {
		width: 56px;
		height: 56px;
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 20px;
	}

	.sim-card-title {
		font-size: 20px;
		font-weight: 700;
		margin-bottom: 10px;
	}

	.sim-card-desc {
		font-size: 14px;
		color: var(--w-color-primary-20);
		line-height: 1.6;
		margin-bottom: 16px;
		flex: 1;
	}

	.sim-card-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
		margin-bottom: 16px;
	}

	.tag {
		padding: 4px 10px;
		background: rgba(10, 189, 227, 0.1);
		border: 1px solid rgba(10, 189, 227, 0.2);
		border-radius: 100px;
		font-size: 11px;
		font-weight: 600;
		color: var(--onee-cyan);
	}

	.sim-card-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(10, 189, 227, 0.1);
		color: var(--onee-cyan);
		transition: all 0.3s;
	}

	.sim-card:hover .sim-card-arrow {
		background: var(--onee-cyan);
		color: #fff;
		transform: translateX(4px);
	}

	/* Steps */
	.steps-grid {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 0;
	}

	.step-item {
		text-align: center;
		padding: 30px;
		max-width: 280px;
	}

	.step-item h3 {
		font-size: 18px;
		font-weight: 700;
		margin-bottom: 8px;
	}

	.step-item p {
		font-size: 14px;
		color: var(--w-color-primary-20);
		line-height: 1.6;
	}

	.step-number {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: linear-gradient(
			135deg,
			var(--onee-cyan),
			var(--onee-blue-light)
		);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		font-weight: 800;
		margin: 0 auto 16px;
	}

	.step-connector {
		width: 60px;
		height: 2px;
		background: var(--onee-card-border);
		margin-top: 52px;
	}

	.section-header {
		text-align: center;
		margin-bottom: 48px;
	}

	@media (max-width: 1024px) {
		.hero .container {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-subtitle {
			margin: 0 auto 32px;
		}
		.hero-actions {
			justify-content: center;
		}
		.hero-visual {
			justify-content: center;
		}
		.hero-title {
			font-size: 38px;
		}
	}

	@media (max-width: 800px) {
		.cards-grid {
			grid-template-columns: 1fr;
		}
		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.steps-grid {
			flex-direction: column;
			align-items: center;
		}
		.step-connector {
			width: 2px;
			height: 30px;
		}
	}

	@media (max-width: 600px) {
		.hero-title {
			font-size: 30px;
		}
		.hero-card {
			width: 100%;
		}
	}
</style>
