---
import Layout from "../layouts/Layout.astro";
---

<Layout title="estimation facture - Simulateur Électricité" activeNav="home">
	<!-- Hero Section -->
	<section class="hero">
		<div class="container">
			<div class="hero-content">
				<div
					class="hero-badge"
					style="animation: fadeInUp 0.5s ease forwards;"
				>
					<span>Simulateur Professionnel</span>
				</div>
				<h1
					class="hero-title"
					style="animation: fadeInUp 0.6s ease forwards; animation-delay: 0.1s;"
				>
					Gérez vos estimations <br />
					<span class="gradient-text">énergétiques</span> avec précision.
				</h1>
				<p
					class="hero-subtitle"
					style="animation: fadeInUp 0.7s ease forwards; animation-delay: 0.2s;"
				>
					Calculez vos consommations Basse Tension et Tarif Général en
					conformité avec les dernières grilles tarifaires officielles
					du Royaume.
				</p>
				<div
					class="hero-actions"
					style="animation: fadeInUp 0.8s ease forwards; animation-delay: 0.3s;"
				>
					<a href="#simulateurs" class="btn btn-primary btn-lg">
						Accéder aux simulateurs
						<svg
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							><path
								d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"></path>
						</svg>
					</a>
					<a href="/tarifs" class="btn btn-secondary btn-lg"
						>Grilles tarifaires</a
					>
				</div>
			</div>
			<div class="hero-visual animate-fade-in delay-3">
				<div class="hero-card glass-card">
					<div class="hero-card-header">
						<span class="hero-card-dot" style="background:#E2E8F0"
						></span>
						<span class="hero-card-dot" style="background:#CBD5E1"
						></span>
						<span class="hero-card-dot" style="background:#94A3B8"
						></span>
					</div>
					<div class="hero-card-body">
						<div class="hero-stat">
							<span class="hero-stat-label">Consommation</span>
							<span
								class="hero-stat-value"
								style="color: var(--onee-blue)">250 kWh</span
							>
						</div>
						<div class="hero-stat">
							<span class="hero-stat-label">Total Estimé</span>
							<span
								class="hero-stat-value"
								style="color: var(--onee-blue)">312.45 DH</span
							>
						</div>
						<div class="hero-bar-chart">
							<div class="hero-bar" style="height: 40%">
								<span>T1</span>
							</div>
							<div class="hero-bar" style="height: 55%">
								<span>T2</span>
							</div>
							<div class="hero-bar active" style="height: 75%">
								<span>T3</span>
							</div>
							<div class="hero-bar" style="height: 60%">
								<span>T4</span>
							</div>
							<div class="hero-bar" style="height: 45%">
								<span>T5</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Stats Section -->
	<section class="stats-section">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-item animate-fade-in-up delay-1">
					<div class="stat-number">6</div>
					<div class="stat-label">Tranches tarifaires</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-2">
					<div class="stat-number">4</div>
					<div class="stat-label">Types d'abonnements</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-3">
					<div class="stat-number">3</div>
					<div class="stat-label">Moteurs de calcul</div>
				</div>
				<div class="stat-item animate-fade-in-up delay-4">
					<div class="stat-number">100%</div>
					<div class="stat-label">Accès libre</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Simulators Section -->
	<section class="section" id="simulateurs">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">
					Solutions de <span class="gradient-text">Simulation</span>
				</h2>
				<p class="section-subtitle">
					Outils adaptés selon votre segment de consommation
				</p>
			</div>

			<div class="cards-grid">
				<!-- BT Card -->
				<a
					href="/simulateur-bt"
					class="sim-card glass-card animate-fade-in-up delay-1"
				>
					<div
						class="sim-card-icon"
						style="background: #F1F5F9; color: var(--onee-blue);"
					>
						<svg
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><path
								d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"
							></path><polyline points="9 22 9 12 15 12 15 22"
							></polyline>
						</svg>
					</div>
					<h3 class="sim-card-title">Basse Tension (BT)</h3>
					<p class="sim-card-desc">
						Calculs pour abonnements résidentiels et professionnels.
						Domestique, Patenté et Force Motrice.
					</p>
					<div class="sim-card-tags">
						<span class="tag">Résidentiel</span>
						<span class="tag">Commercial</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="18"
							height="18"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>

				<!-- General Tariff Card -->
				<a
					href="/simulateur-general"
					class="sim-card glass-card animate-fade-in-up delay-2"
				>
					<div
						class="sim-card-icon"
						style="background: #F1F5F9; color: var(--onee-blue);"
					>
						<svg
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><rect x="2" y="7" width="20" height="14" rx="2"
							></rect><path
								d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"
							></path><line x1="12" y1="12" x2="12" y2="16"
							></line>
						</svg>
					</div>
					<h3 class="sim-card-title">Haut/Très Haute Tension</h3>
					<p class="sim-card-desc">
						Simulateur industriel pour abonnements HT/THT. Prise en
						charge des options TLU, MU, CU et TCU.
					</p>
					<div class="sim-card-tags">
						<span class="tag">Industriel</span>
						<span class="tag">ANRE 2025</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="18"
							height="18"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>

				<!-- Tarifs Card -->
				<a
					href="/tarifs"
					class="sim-card glass-card animate-fade-in-up delay-3"
				>
					<div
						class="sim-card-icon"
						style="background: #F1F5F9; color: var(--onee-blue);"
					>
						<svg
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><path
								d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
							></path><polyline points="14 2 14 8 20 8"
							></polyline><line x1="16" y1="13" x2="8" y2="13"
							></line><line x1="16" y1="17" x2="8" y2="17"></line>
						</svg>
					</div>
					<h3 class="sim-card-title">Référentiel Tarifaire</h3>
					<p class="sim-card-desc">
						Accédez à l'ensemble des grilles de prix unitaires,
						taxes et redevances fixes en vigueur.
					</p>
					<div class="sim-card-tags">
						<span class="tag">Documentation</span>
						<span class="tag">Officiel</span>
					</div>
					<div class="sim-card-arrow">
						<svg
							width="18"
							height="18"
							viewBox="0 0 20 20"
							fill="none"
							><path
								d="M4 10H16M16 10L11 5M16 10L11 15"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"></path>
						</svg>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="section how-section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">
					Méthodologie de <span class="gradient-text">Calcul</span>
				</h2>
				<p class="section-subtitle">
					Une approche structurée pour une précision maximale
				</p>
			</div>
			<div class="steps-grid">
				<div class="step-item animate-fade-in-up delay-1">
					<div class="step-number">01</div>
					<h3>Configuration</h3>
					<p>
						Définissez votre profil de consommation et les
						paramètres techniques
					</p>
				</div>
				<div class="step-connector"></div>
				<div class="step-item animate-fade-in-up delay-2">
					<div class="step-number">02</div>
					<h3>Saisie</h3>
					<p>
						Indiquez vos relevés d'index ou votre consommation
						globale mensuelle
					</p>
				</div>
				<div class="step-connector"></div>
				<div class="step-item animate-fade-in-up delay-3">
					<div class="step-number">03</div>
					<h3>Analyse</h3>
					<p>
						Obtenez une décomposition détaillée de chaque composante
						de votre facture
					</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding: 100px 0 60px;
		position: relative;
		overflow: hidden;
	}

	.hero .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.hero-badge {
		display: inline-flex;
		padding: 6px 14px;
		background: #f1f5f9;
		border-radius: 6px;
		font-size: 12px;
		font-weight: 800;
		color: var(--onee-blue);
		margin-bottom: 24px;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.hero-title {
		font-size: 48px;
		font-weight: 800;
		line-height: 1.15;
		margin-bottom: 24px;
		color: var(--onee-blue);
		letter-spacing: -1px;
	}

	.hero-subtitle {
		font-size: 16px;
		color: var(--w-color-primary-20);
		line-height: 1.7;
		margin-bottom: 40px;
		max-width: 500px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.hero-visual {
		display: flex;
		justify-content: flex-end;
	}

	.hero-card {
		width: 360px;
		padding: 0;
		overflow: hidden;
		background: #fff;
		border: 1px solid #e2e8f0;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
	}

	.hero-card-header {
		display: flex;
		gap: 6px;
		padding: 14px 20px;
		border-bottom: 1px solid #f1f5f9;
	}

	.hero-card-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.hero-card-body {
		padding: 24px;
	}

	.hero-stat {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 20px;
	}

	.hero-stat-label {
		font-size: 13px;
		font-weight: 600;
		color: #64748b;
	}

	.hero-stat-value {
		font-size: 18px;
		font-weight: 800;
	}

	.hero-bar-chart {
		display: flex;
		align-items: flex-end;
		gap: 10px;
		height: 100px;
		padding-top: 20px;
		border-top: 1px solid #f1f5f9;
	}

	.hero-bar {
		flex: 1;
		background: #f1f5f9;
		border-radius: 4px 4px 0 0;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding-bottom: 8px;
		transition: all 0.3s;
	}

	.hero-bar.active {
		background: #e2e8f0;
	}

	.hero-bar span {
		font-size: 10px;
		font-weight: 700;
		color: #94a3b8;
	}

	.stats-section {
		padding: 80px 0;
		background: #fff;
		border-top: 1px solid var(--onee-card-border);
		border-bottom: 1px solid var(--onee-card-border);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.stat-item {
		text-align: center;
		padding: 40px 24px;
		border-radius: 12px;
		background: var(--onee-background);
		border: 1px solid var(--onee-card-border);
		transition: all 0.3s ease;

		&:hover {
			border-color: var(--onee-blue);
			background: #fff;
			transform: translateY(-4px);
			box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
		}
	}

	.stat-number {
		font-size: 40px;
		font-weight: 900;
		color: var(--onee-blue);
		margin-bottom: 8px;
		letter-spacing: -1px;
	}

	.stat-label {
		font-size: 14px;
		font-weight: 700;
		color: var(--w-color-primary-30);
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}

	.sim-card {
		padding: 40px;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid var(--onee-card-border);
		background: #fff;
		border-radius: 16px;
	}

	.sim-card:hover {
		transform: translateY(-12px);
		border-color: var(--onee-blue);
		box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.08);
	}

	.sim-card-icon {
		width: 60px;
		height: 60px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 28px;
		transition: all 0.3s ease;
	}

	.sim-card:hover .sim-card-icon {
		background: var(--onee-blue) !important;
		color: #fff !important;
		transform: rotate(-5deg) scale(1.1);
	}

	.sim-card-title {
		font-size: 20px;
		font-weight: 800;
		margin-bottom: 16px;
		color: var(--onee-blue);
	}

	.sim-card-desc {
		font-size: 15px;
		color: var(--w-color-primary-30);
		line-height: 1.6;
		margin-bottom: 28px;
		flex: 1;
	}

	.sim-card-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-bottom: 32px;
	}

	.tag {
		padding: 4px 12px;
		background: var(--onee-background);
		border-radius: 6px;
		font-size: 11px;
		font-weight: 800;
		color: var(--w-color-primary-30);
		text-transform: uppercase;
		border: 1px solid var(--onee-card-border);
	}

	.sim-card-arrow {
		display: flex;
		align-items: center;
		padding-top: 20px;
		border-top: 1px solid var(--onee-background);
		gap: 12px;
		color: var(--onee-blue);
		font-weight: 800;
		font-size: 14px;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.sim-card-arrow svg {
		transition: transform 0.3s ease;
	}

	.sim-card:hover .sim-card-arrow svg {
		transform: translateX(6px);
	}

	.steps-grid {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		margin: 60px 0;
	}

	.step-item {
		text-align: center;
		padding: 0 40px;
		flex: 1;
		max-width: 320px;
	}

	.step-number {
		width: 56px;
		height: 56px;
		background: var(--onee-blue);
		color: #fff;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		font-weight: 900;
		margin: 0 auto 28px;
		box-shadow: 0 8px 16px rgba(0, 51, 102, 0.15);
		border: 4px solid #fff;
		outline: 1px solid var(--onee-blue);
	}

	.step-item h3 {
		font-size: 18px;
		font-weight: 800;
		margin-bottom: 16px;
		color: var(--onee-blue);
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.step-item p {
		font-size: 15px;
		color: var(--w-color-primary-30);
		line-height: 1.6;
		font-weight: 500;
	}

	.step-connector {
		flex: 1;
		max-width: 120px;
		height: 2px;
		background: var(--onee-background);
		margin-top: 28px;
		border-top: 2px dashed var(--onee-card-border);
	}

	@media (max-width: 1024px) {
		.hero .container {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-subtitle {
			margin: 0 auto 40px;
		}
		.hero-actions {
			justify-content: center;
		}
		.hero-visual {
			justify-content: center;
		}
		.hero-title {
			font-size: 36px;
		}
		.steps-grid {
			flex-direction: column;
			align-items: center;
			gap: 60px;
		}
		.step-connector {
			display: none;
		}
	}

	@media (max-width: 800px) {
		.cards-grid {
			grid-template-columns: 1fr;
		}
		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
