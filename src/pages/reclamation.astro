---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Générateur de Réclamation - estimation facture"
    activeNav="historique"
>
    <section class="section">
        <div class="container" style="max-width: 900px;">
            <div class="section-header">
                <h1 class="section-title">
                    Générateur de <span class="gradient-text">Réclamation</span>
                </h1>
                <p class="section-subtitle">
                    Générez un document formel basé sur votre estimation pour
                    contester un montant ou demander des explications.
                </p>
            </div>

            <div class="reclamation-layout">
                <!-- Form Sheet -->
                <div class="form-panel" id="formPanel">
                    <div class="form-panel-handle"></div>
                    <div class="form-panel-header">
                        <div>
                            <span class="step-indicator">01.</span> Éditer les Informations
                        </div>
                        <button class="close-btn" id="closeFormBtn"
                            >&times;</button
                        >
                    </div>

                    <div class="form-panel-content page-card">
                        <div class="form-group">
                            <label>Prestataire de service</label>
                            <select id="provider" class="form-select">
                                <optgroup
                                    label="Sociétés Régionales Multi-services (SRM)"
                                >
                                    <option value="SRM Casablanca-Settat"
                                        >SRM Casablanca-Settat</option
                                    >
                                    <option value="SRM Marrakech-Safi"
                                        >SRM Marrakech-Safi</option
                                    >
                                    <option value="SRM Souss-Massa"
                                        >SRM Souss-Massa</option
                                    >
                                    <option value="SRM Oriental"
                                        >SRM Oriental</option
                                    >
                                    <option value="SRM Rabat-Salé-Kénitra"
                                        >SRM Rabat-Salé-Kénitra</option
                                    >
                                    <option
                                        value="SRM Tanger-Tétouan-Al Hoceïma"
                                        >SRM Tanger-Tétouan-Al Hoceïma</option
                                    >
                                </optgroup>
                                <optgroup
                                    label="Opérateurs Historiques / Autres"
                                >
                                    <option value="ONEE (Branche Électricité)"
                                        >ONEE (Branche Électricité)</option
                                    >
                                    <option value="Lydec"
                                        >Lydec (Transition SRM)</option
                                    >
                                    <option value="Redal"
                                        >Redal (Transition SRM)</option
                                    >
                                    <option value="Amendis"
                                        >Amendis (Transition SRM)</option
                                    >
                                    <option value="other"
                                        >Autre SRM ou Régie...</option
                                    >
                                </optgroup>
                            </select>
                        </div>

                        <div
                            class="form-group"
                            id="customProviderGroup"
                            style="display: none;"
                        >
                            <label>Nom du prestataire personnalisé</label>
                            <input
                                type="text"
                                id="customProvider"
                                class="form-input"
                                placeholder="Nom de la régie ou société"
                            />
                        </div>

                        <div class="grid grid-2" style="gap:16px">
                            <div class="form-group">
                                <label>Nom complet / Raison Sociale</label>
                                <input
                                    type="text"
                                    id="userName"
                                    class="form-input"
                                    placeholder="Ex: Ahmed El Mansouri"
                                />
                            </div>
                            <div class="form-group">
                                <label>Ville</label>
                                <input
                                    type="text"
                                    id="city"
                                    class="form-input"
                                    placeholder="Ex: Casablanca"
                                    value="Casablanca"
                                />
                            </div>
                        </div>

                        <div class="grid grid-2" style="gap:16px">
                            <div class="form-group">
                                <label>N° de Contrat</label>
                                <input
                                    type="text"
                                    id="contractId"
                                    class="form-input"
                                    placeholder="Ex: 123456789"
                                />
                            </div>
                            <div class="form-group">
                                <label>Objet Principal</label>
                                <select id="reason" class="form-select">
                                    <option value="overcharge"
                                        >Montant excessif</option
                                    >
                                    <option value="tranche"
                                        >Calcul tranches</option
                                    >
                                    <option value="tppa">Taxe TPPA</option>
                                    <option value="other">Autre demande</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Détails & Arguments</label>
                            <textarea
                                id="extraDetails"
                                class="form-input"
                                style="height: 120px; resize: none;"
                                placeholder="Décrivez les faits avec précision..."
                            ></textarea>
                        </div>

                        <div
                            style="margin-top: 32px; padding: 20px; background: var(--onee-background); border-radius: 8px; border: 1px solid var(--onee-card-border);"
                        >
                            <p
                                style="font-size: 12px; color: var(--w-color-primary-30); font-weight: 600; line-height: 1.6;"
                            >
                                <strong style="color:var(--onee-blue)"
                                    >Rappel Légal :</strong
                                > Ce document est conforme à la Loi 55.19 (Simplification
                                administrative) et Loi 31.13 (Droit à l'information).
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Preview Area -->
                <div class="preview-panel animate-fade-in">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; padding: 0 8px;"
                    >
                        <h2
                            style="font-size: 13px; font-weight: 800; text-transform: uppercase; color: var(--onee-blue); letter-spacing: 1px;"
                        >
                            Aperçu de l'Audit
                        </h2>
                        <div class="no-print" style="display:flex; gap:12px">
                            <button
                                class="btn btn-primary"
                                id="exportPDF"
                                style="padding: 10px 24px; font-size: 13px;"
                            >
                                Télécharger PDF
                            </button>
                        </div>
                    </div>

                    <div
                        id="documentPreview"
                        class="bill-card"
                        style="color: #0F172A; padding: 60px; min-height: 700px; background: #fff; box-shadow: 0 20px 50px rgba(0,0,0,0.08); border-radius: 4px; font-family: Arial, Helvetica, sans-serif; font-size: 12pt; line-height: 1.5;"
                    >
                        <!-- Content injected here -->
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .reclamation-layout {
        display: grid;
        grid-template-columns: 450px 1fr;
        gap: 40px;
        align-items: start;
    }
    .form-panel {
        background: var(--onee-card-bg);
        border: 1px solid var(--onee-card-border);
        border-radius: var(--w-md-radius);
        margin: 0;
    }
    .form-panel-handle {
        display: none;
    }
    .form-panel-header {
        display: none;
    }
    .preview-panel {
        position: sticky;
        top: 20px;
    }

    /* Mobile Bottom Sheet */
    @media (max-width: 1024px) {
        .reclamation-layout {
            display: block;
        }
        .preview-panel {
            position: relative;
            top: 0;
            padding-bottom: 120px; /* Space for the collapsed sheet */
        }
        .form-panel {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            border-radius: 24px 24px 0 0;
            box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.15);
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            transform: translateY(
                calc(100% - 80px)
            ); /* show only the handle/header */
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-bottom: none;
        }
        @media (prefers-color-scheme: dark) {
            .form-panel {
                box-shadow: 0 -10px 50px rgba(0, 0, 0, 0.6);
            }
        }
        .form-panel.open {
            transform: translateY(0);
        }
        .form-panel-handle {
            display: block;
            width: 48px;
            height: 5px;
            background: var(--w-color-primary-40);
            border-radius: 999px;
            margin: 16px auto;
            cursor: pointer;
        }
        .form-panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 24px 16px;
            font-weight: 800;
            color: var(--onee-blue);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 13px;
            cursor: pointer;
            border-bottom: 1px solid var(--onee-card-border);
        }
        .form-panel-content {
            overflow-y: auto;
        }
        .step-indicator {
            color: var(--onee-blue);
            opacity: 0.5;
            margin-right: 8px;
        }
        .close-btn {
            display: none;
            background: none;
            border: none;
            font-size: 24px;
            color: var(--w-color-primary-30);
            cursor: pointer;
            line-height: 1;
            padding: 0 8px;
        }
        .form-panel.open .close-btn {
            display: block;
        }
    }
</style>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    const estId = urlParams.get("id");
    const history = JSON.parse(
        localStorage.getItem("estimation_history") || "[]"
    );
    const estimation = history.find((h: any) => h.id.toString() === estId);

    function updatePreviewRec() {
        const providerSelect = document.getElementById(
            "provider"
        ) as unknown as HTMLSelectElement;
        const customProviderInput = document.getElementById(
            "customProvider"
        ) as HTMLInputElement;
        const customProviderGroup = document.getElementById(
            "customProviderGroup"
        )!;

        let providerName = providerSelect.value;
        if (providerName === "other") {
            customProviderGroup.style.display = "block";
            providerName = customProviderInput.value || "[Nom du prestataire]";
        } else {
            customProviderGroup.style.display = "none";
        }

        const name =
            (document.getElementById("userName") as HTMLInputElement).value ||
            "[Votre Nom / Raison Sociale]";
        const city =
            (document.getElementById("city") as HTMLInputElement).value ||
            "Casablanca";
        const contract =
            (document.getElementById("contractId") as HTMLInputElement).value ||
            "[N° de Police]";
        const reasonSelect = document.getElementById(
            "reason"
        ) as unknown as HTMLSelectElement;
        const reasonText =
            reasonSelect.options[reasonSelect.selectedIndex].text;
        const extra = (
            document.getElementById("extraDetails") as HTMLTextAreaElement
        ).value;
        const date = new Date().toLocaleDateString("fr-FR", {
            day: "numeric",
            month: "long",
            year: "numeric",
        });

        const estDetails = estimation
            ? `
            <div style="background: #F8FAFC; padding: 24px; border-radius: 8px; margin: 24px 0; border: 1px solid #E2E8F0; font-size: 13px; line-height: 1.8;">
                <div style="font-weight: 800; color: #003366; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; font-size: 11px;">Données de Référence :</div>
                <strong>Estimation :</strong> ${estimation.label}<br>
                <strong>Date :</strong> ${new Date(
                    estimation.date
                ).toLocaleDateString()}<br>
                <strong>Montant Audit :</strong> ${estimation.total.toFixed(
                    2
                )} DH HT
            </div>
        `
            : "";

        const preview = document.getElementById("documentPreview")!;
        preview.innerHTML = `
            <div style="display: flex; justify-content: space-between; margin-bottom: 60px; border-bottom: 1px solid #E2E8F0; padding-bottom: 32px;">
                <div style="color: #1E293B;">
                    <div style="font-weight: 800; color: #003366; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-size: 10pt;">EXPÉDITEUR</div>
                    <strong style="font-size: 13pt;">${name}</strong><br>
                    Contrat N° : ${contract}<br>
                    Secteur : Basse Tension / Tarif Général
                </div>
                <div style="text-align: right; color: #64748B;">
                    Fait à ${city}, le<br>
                    <strong style="color: #1E293B;">${date}</strong>
                </div>
            </div>

            <div style="margin-bottom: 64px; margin-left: auto; width: fit-content; max-width: 60%; text-align: left; background: #F1F5F9; padding: 24px; border-radius: 8px; border: 1px solid #E2E8F0;">
                <div style="font-weight: 800; color: #003366; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-size: 10pt;">DESTINATAIRE</div>
                <strong>À Monsieur le Directeur Général</strong><br>
                ${providerName}<br>
                <span style="font-size: 10pt; opacity: 0.8;">Service Clients & Réclamations</span>
            </div>

            <div style="margin-bottom: 40px; padding: 16px; border-left: 4px solid #003366; background: #F8FAFC;">
                <strong style="font-size: 10pt; color: #64748B; text-transform: uppercase; letter-spacing: 1px;">Objet :</strong><br>
                <strong style="font-size: 13pt; color: #003366;">DEMANDE DE VÉRIFICATION DE FACTURATION — ${reasonText.toUpperCase()}</strong>
            </div>

            <div style="color: #1E293B; text-align: justify;">
                <p style="margin-bottom: 24px;">Monsieur le Directeur,</p>

                <p style="margin-bottom: 20px;">Par la présente, je sollicite votre intervention concernant les modalités de facturation appliquées à mon contrat cité en référence. À la suite d'un audit interne basé sur les grilles tarifaires officielles en vigueur au Royaume du Maroc, une divergence technique a été identifiée.</p>

                ${estDetails}

                <p style="margin-bottom: 20px;">${
                    extra ||
                    "Les éléments en ma possession suggèrent une anomalie dans l'application des tranches tarifaires ou des redevances fixes. Je vous demande par conséquent de bien vouloir procéder à une revue exhaustive des index facturés et de me fournir une décomposition détaillée justifiant les montants prélevés."
                }</p>

                <p style="margin-bottom: 24px;">Cette démarche s'inscrit dans le cadre de mes droits fondamentaux garantis par la <strong>Loi n° 55.19</strong> relative à la simplification des procédures administratives et la <strong>Loi n° 31.13</strong> relative au droit d'accès à l'information.</p>

                <p style="margin-bottom: 60px;">Dans l'attente d'une réponse de vos services sous les délais légaux prescrits, je vous prie d'agréer, Monsieur le Directeur, l'expression de ma considération distinguée.</p>
            </div>

            <div style="display: flex; justify-content: flex-end; margin-top: 40px;">
                <div style="text-align: center; width: 250px;">
                    <p style="font-size: 12px; color: #64748B; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 40px;">Signature du Client</p>
                    <div style="border-top: 1px solid #E2E8F0; width: 100%;"></div>
                </div>
            </div>
        `;
        const formPanel = document.getElementById("formPanel");
        const formHeader = document.querySelector(".form-panel-header");
        const formHandle = document.querySelector(".form-panel-handle");
        const closeBtn = document.getElementById("closeFormBtn");

        [formHeader, formHandle].forEach((el) => {
            el?.addEventListener("click", (e) => {
                if (window.innerWidth <= 1024 && e.target !== closeBtn) {
                    formPanel?.classList.toggle("open");
                }
            });
        });

        closeBtn?.addEventListener("click", () => {
            formPanel?.classList.remove("open");
        });

        // Toggle open on input focus in mobile
        document.querySelectorAll(".form-input, .form-select").forEach((el) => {
            el.addEventListener("focus", () => {
                if (window.innerWidth <= 1024) {
                    formPanel?.classList.add("open");
                }
            });
        });
    }

    [
        "provider",
        "customProvider",
        "userName",
        "city",
        "contractId",
        "reason",
        "extraDetails",
    ].forEach((id) => {
        document
            .getElementById(id)
            ?.addEventListener("input", updatePreviewRec);
    });

    // Initial
    updatePreviewRec();

    // Export PDF
    document
        .getElementById("exportPDF")
        ?.addEventListener("click", async () => {
            const btn = document.getElementById(
                "exportPDF"
            ) as HTMLButtonElement;
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = "Génération...";

            // Load jsPDF from CDN
            const script = document.createElement("script");
            script.src =
                "https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js";
            document.head.appendChild(script);

            script.onload = () => {
                // @ts-ignore
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();

                // Get dynamic values
                const name =
                    (document.getElementById("userName") as HTMLInputElement)
                        .value || "NOM ET PRÉNOM";
                const city =
                    (document.getElementById("city") as HTMLInputElement)
                        .value || "Casablanca";
                const contract =
                    (document.getElementById("contractId") as HTMLInputElement)
                        .value || "12345678";

                const providerSelect = document.getElementById(
                    "provider"
                ) as unknown as HTMLSelectElement;
                let providerName = providerSelect.value;
                if (providerName === "other") {
                    providerName =
                        (
                            document.getElementById(
                                "customProvider"
                            ) as HTMLInputElement
                        ).value || "LE DIRECTEUR DE L'AGENCE";
                }

                const reasonSelect = document.getElementById(
                    "reason"
                ) as unknown as HTMLSelectElement;
                const reasonText =
                    reasonSelect.options[
                        reasonSelect.selectedIndex
                    ].text.toUpperCase();

                const extra = (
                    document.getElementById(
                        "extraDetails"
                    ) as HTMLTextAreaElement
                ).value;
                const date = new Date().toLocaleDateString("fr-FR");

                // Layout settings
                let y = 30;
                const xMargin = 20;

                doc.setFont("helvetica");

                // Header Left (Expéditeur)
                doc.setFontSize(10);
                doc.setFont("helvetica", "bold");
                doc.setTextColor(0, 51, 102);
                doc.text("EXPÉDITEUR", xMargin, y);
                y += 6;
                doc.setTextColor(30, 41, 59);
                doc.setFontSize(12);
                doc.text(name, xMargin, y);
                y += 6;
                doc.setFont("helvetica", "normal");
                doc.setFontSize(11);
                doc.text(`Contrat N° : ${contract}`, xMargin, y);
                y += 6;
                doc.text("Secteur : Basse Tension / Tarif Général", xMargin, y);

                // Header Right (Date)
                doc.setFontSize(11);
                doc.text(`Fait à ${city}, le ${date}`, 140, y - 12);

                y += 20;
                doc.setDrawColor(226, 232, 240);
                doc.line(xMargin, y, 190, y);
                y += 20;

                // Destinataire
                doc.setFont("helvetica", "bold");
                doc.setFontSize(10);
                doc.setTextColor(0, 51, 102);
                doc.text("DESTINATAIRE", 110, y);
                y += 6;
                doc.setTextColor(30, 41, 59);
                doc.setFontSize(11);
                doc.text("À Monsieur le Directeur Général", 110, y);
                y += 6;
                doc.setFont("helvetica", "normal");
                doc.text(providerName, 110, y);
                y += 6;
                doc.setFontSize(10);
                doc.setTextColor(100, 116, 139);
                doc.text("Service Clients & Réclamations", 110, y);

                y += 30;

                // Objet
                doc.setFont("helvetica", "bold");
                doc.setFontSize(10);
                doc.setTextColor(100, 116, 139);
                doc.text("Objet :", xMargin, y);
                y += 8;
                doc.setFontSize(12);
                doc.setTextColor(0, 51, 102);
                doc.text(
                    `DEMANDE DE VÉRIFICATION DE FACTURATION — ${reasonText}`,
                    xMargin,
                    y
                );

                y += 25;

                // Body text
                doc.setFont("helvetica", "normal");
                doc.setFontSize(11);
                doc.setTextColor(30, 41, 59);

                let bodyText = `Monsieur le Directeur,\n\nPar la présente, je sollicite votre intervention concernant les modalités de facturation appliquées à mon contrat cité en référence. À la suite d'un audit interne basé sur les grilles tarifaires officielles en vigueur au Royaume du Maroc, une divergence technique a été identifiée.`;

                if (estimation) {
                    bodyText += `\n\nDonnées de Référence de l'Estimation :\n- Date : ${new Date(
                        estimation.date
                    ).toLocaleDateString()}\n- Montant Audit : ${estimation.total.toFixed(
                        2
                    )} DH HT`;
                }

                if (extra) {
                    bodyText += `\n\n${extra}`;
                } else {
                    bodyText += `\n\nLes éléments en ma possession suggèrent une anomalie dans l'application des tranches tarifaires ou des redevances fixes. Je vous demande par conséquent de bien vouloir procéder à une revue exhaustive des index facturés et de me fournir une décomposition détaillée justifiant les montants prélevés.`;
                }

                bodyText += `\n\nCette démarche s'inscrit dans le cadre de mes droits fondamentaux garantis par la Loi n° 55.19 relative à la simplification des procédures administratives et la Loi n° 31.13 relative au droit d'accès à l'information.\n\nDans l'attente d'une réponse de vos services sous les délais légaux prescrits, je vous prie d'agréer, Monsieur le Directeur, l'expression de ma considération distinguée.`;

                // Split and print text
                const lines = doc.splitTextToSize(bodyText, 170);
                doc.text(lines, xMargin, y);

                // Signature area
                y += lines.length * 6 + 30;
                doc.setFont("helvetica", "bold");
                doc.setFontSize(11);
                doc.setTextColor(100, 116, 139);
                doc.text("Signature du Client", 140, y);
                y += 15;
                doc.line(130, y, 180, y);

                // Save
                doc.save(`reclamation-electricite-${new Date().getTime()}.pdf`);

                btn.disabled = false;
                btn.textContent = originalText;
            };
        });
    export {};
</script>

<style is:global>
    @media print {
        header,
        footer,
        .section-header,
        .bill-card:not(:has(#documentPreview)),
        .no-print,
        nav {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        html,
        body {
            background: #fff !important;
            color: #000 !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .container {
            max-width: 100% !important;
            width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .bill-card:has(#documentPreview) {
            background: transparent !important;
            border: none !important;
            padding: 0 !important;
            margin: 0 !important;
            box-shadow: none !important;
        }

        #documentPreview {
            box-shadow: none !important;
            border: none !important;
            padding: 15mm !important;
            width: 100% !important;
            min-height: auto !important;
            background: #fff !important;
            color: #000 !important;
            font-size: 11pt !important;
        }

        #documentPreview * {
            visibility: visible !important;
        }

        @page {
            margin: 1cm;
            size: A4;
        }
    }
</style>
