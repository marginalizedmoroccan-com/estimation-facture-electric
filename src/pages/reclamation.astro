---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Générateur de Réclamation - estimation facture"
    activeNav="historique"
>
    <section class="section">
        <div class="container" style="max-width: 900px;">
            <div class="section-header">
                <h1 class="section-title">
                    Générateur de <span class="gradient-text">Réclamation</span>
                </h1>
                <p class="section-subtitle">
                    Générez un document formel basé sur votre estimation pour
                    contester un montant ou demander des explications.
                </p>
            </div>

            <div class="grid grid-2" style="gap: 32px; align-items: start;">
                <!-- Form -->
                <div class="bill-card" style="margin:0">
                    <div style="padding: 32px;">
                        <h2
                            style="font-size: 18px; font-weight: 700; margin-bottom: 24px;"
                        >
                            Vos Informations
                        </h2>

                        <div class="form-group">
                            <label>Prestataire de service</label>
                            <select id="provider" class="form-input">
                                <option value="ONEE"
                                    >ONEE (Branche Électricité)</option
                                >
                                <option value="Lydec">Lydec (Casablanca)</option
                                >
                                <option value="Redal">Redal (Rabat-Salé)</option
                                >
                                <option value="Amendis"
                                    >Amendis (Tanger-Tétouan)</option
                                >
                                <option value="other">Autre...</option>
                            </select>
                        </div>

                        <div
                            class="form-group"
                            id="customProviderGroup"
                            style="display: none;"
                        >
                            <label>Nom du prestataire personnalisé</label>
                            <input
                                type="text"
                                id="customProvider"
                                class="form-input"
                                placeholder="Nom de la régie ou société"
                            />
                        </div>

                        <div class="form-group">
                            <label>Nom complet / Raison Sociale</label>
                            <input
                                type="text"
                                id="userName"
                                class="form-input"
                                placeholder="Ex: Ahmed El Mansouri"
                            />
                        </div>

                        <div class="form-group">
                            <label>N° de Contrat / Police</label>
                            <input
                                type="text"
                                id="contractId"
                                class="form-input"
                                placeholder="Ex: 123456789"
                            />
                        </div>

                        <div class="form-group">
                            <label>Objet de la réclamation</label>
                            <select id="reason" class="form-input">
                                <option value="overcharge"
                                    >Montant estimé trop élevé par rapport au
                                    réel</option
                                >
                                <option value="tranche"
                                    >Erreur suspectée dans le calcul des
                                    tranches</option
                                >
                                <option value="tppa"
                                    >Application incorrecte de la taxe TPPA</option
                                >
                                <option value="other"
                                    >Autre demande d'information</option
                                >
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Détails supplémentaires</label>
                            <textarea
                                id="extraDetails"
                                class="form-input"
                                style="height: 100px; resize: none;"
                                placeholder="Précisez votre demande..."
                            ></textarea>
                        </div>

                        <div
                            style="margin-top: 24px; padding: 16px; background: rgba(212,168,67,0.1); border-radius: 8px; border-left: 3px solid var(--onee-gold);"
                        >
                            <p
                                style="font-size: 12px; color: var(--onee-gold);"
                            >
                                💡 <strong>Base Légale :</strong> Ce document invoque
                                la <strong>Loi 55.19</strong> sur la simplification
                                des procédures et la <strong>Loi 31.13</strong> sur
                                le droit d'accès à l'information.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Preview Area -->
                <div
                    class="bill-card animate-fade-in"
                    style="margin:0; position: sticky; top: 20px;"
                >
                    <div style="padding: 32px;">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;"
                        >
                            <h2 style="font-size: 16px; font-weight: 700;">
                                Aperçu du document
                            </h2>
                            <div class="no-print">
                                <button
                                    class="btn btn-primary btn-sm"
                                    onclick="window.print()"
                                    >Exporter PDF</button
                                >
                            </div>
                        </div>

                        <div
                            id="documentPreview"
                            class="glass-card"
                            style="padding: 32px; font-family: 'Times New Roman', serif; color: #333; background: #fff; line-height: 1.5; min-height: 500px; font-size: 14px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);"
                        >
                            <!-- Content injected here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    const estId = urlParams.get("id");
    const history = JSON.parse(
        localStorage.getItem("estimation_history") || "[]"
    );
    const estimation = history.find((h: any) => h.id.toString() === estId);

    function updatePreview() {
        const providerSelect = document.getElementById(
            "provider"
        ) as unknown as HTMLSelectElement;
        const customProviderInput = document.getElementById(
            "customProvider"
        ) as HTMLInputElement;
        const customProviderGroup = document.getElementById(
            "customProviderGroup"
        )!;

        let providerName = providerSelect.value;
        if (providerName === "other") {
            customProviderGroup.style.display = "block";
            providerName = customProviderInput.value || "[Nom du prestataire]";
        } else {
            customProviderGroup.style.display = "none";
        }

        const name =
            (document.getElementById("userName") as HTMLInputElement).value ||
            "[Votre Nom]";
        const contract =
            (document.getElementById("contractId") as HTMLInputElement).value ||
            "[N° Contrat]";
        const reasonSelect = document.getElementById(
            "reason"
        ) as unknown as HTMLSelectElement;
        const reasonText =
            reasonSelect.options[reasonSelect.selectedIndex].text;
        const extra = (
            document.getElementById("extraDetails") as HTMLTextAreaElement
        ).value;
        const date = new Date().toLocaleDateString("fr-FR");

        const estDetails = estimation
            ? `
            <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin: 15px 0; border: 1px solid #dee2e6;">
                <strong>Détails de l'estimation de référence :</strong><br>
                Config : ${estimation.label}<br>
                Montant simulé : ${estimation.total.toFixed(2)} DH TTC
            </div>
        `
            : "";

        const preview = document.getElementById("documentPreview")!;
        preview.innerHTML = `
            <div style="display: flex; justify-content: space-between; margin-bottom: 50px;">
                <div style="font-size: 13px;">
                    <strong>EXPÉDITEUR :</strong><br>
                    ${name}<br>
                    Contrat N° : ${contract}
                </div>
                <div style="text-align: right; font-size: 13px;">
                    Fait le : ${date}
                </div>
            </div>

            <div style="margin-bottom: 40px; margin-left: auto; width: fit-content; max-width: 60%; text-align: left;">
                <strong>À l'attention de Monsieur le Directeur</strong><br>
                Département Clientèle - ${providerName}<br>
                Royaume du Maroc
            </div>

            <div style="margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                <strong>OBJET : ${reasonText.toUpperCase()}</strong>
            </div>

            <p>Monsieur le Directeur,</p>

            <p style="text-indent: 30px; margin-bottom: 15px;">Par la présente, je tiens à porter à votre connaissance une réclamation concernant ma consommation d'électricité. Après avoir effectué une simulation basée sur les tarifs officiels en vigueur (Arrêtés ministériels fixant les tarifs de vente de l'énergie électrique), j'ai constaté une divergence que je souhaiterais clarifier.</p>

            ${estDetails}

            <p style="text-indent: 30px; margin-bottom: 15px;">${
                extra ||
                "Je vous prie de bien vouloir procéder à une vérification de mon compteur ou de m'apporter des précisions sur le mode de calcul appliqué à ma dernière facture."
            }</p>

            <p style="margin-bottom: 20px;">Cette demande s'inscrit dans le cadre de mes droits garantis par la <strong>Loi n° 55.19</strong> relative à la simplification des procédures administratives et la <strong>Loi n° 31.13</strong> relative au droit d'accès à l'information.</p>

            <p style="margin-bottom: 40px;">Dans l'attente d'une réponse de votre part sous les délais réglementaires, je vous prie d'agréer, Monsieur le Directeur, l'expression de mes salutations distinguées.</p>

            <div style="margin-top: 50px; text-align: right; padding-right: 50px;">
                <p><strong>Signature :</strong></p>
                <div style="margin-top: 40px; border-top: 1px dashed #ccc; width: 150px; margin-left: auto;"></div>
            </div>
        `;
    }

    [
        "provider",
        "customProvider",
        "userName",
        "contractId",
        "reason",
        "extraDetails",
    ].forEach((id) => {
        document.getElementById(id)?.addEventListener("input", updatePreview);
    });

    // Initial
    updatePreview();
</script>

<style>
    @media print {
        @page {
            margin: 20mm;
            size: A4;
        }
        body {
            background: #fff !important;
            color: #000 !important;
        }
        header,
        footer,
        .section-header,
        .bill-card:not(:has(#documentPreview)),
        .no-print {
            display: none !important;
        }
        .container {
            max-width: 100% !important;
            width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        section {
            padding: 0 !important;
            margin: 0 !important;
        }
        #documentPreview {
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
            min-height: auto !important;
            width: 100% !important;
            visibility: visible !important;
            background: #fff !important;
            color: #000 !important;
            position: relative !important;
            font-size: 11pt !important;
            display: block !important;
        }
        .bill-card:has(#documentPreview) {
            background: transparent !important;
            border: none !important;
            padding: 0 !important;
            margin: 0 !important;
            box-shadow: none !important;
            visibility: visible !important;
            display: block !important;
            position: relative !important;
        }
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }
</style>
